# Build artifacts.
.stack-work/
stack.yaml.lock
hydra-json-driver.cabal

# headmods/ holds build-time copies of the 4 head generation modules
# (Generation, PackageRouting, TargetFilePaths, Digest), refreshed from the
# canonical heads/haskell/src/main/haskell source by bin/cold-seed-dist-haskell.sh
# on every run. Generated artifact — never hand-edited, never committed.
headmods/

# typesmods/ (#608) holds a build-time copy of the Terms-free DSL Types subtree
# — Hydra/Sources/Kernel/Types/** plus the single Hydra/Sources/Json/Model.hs it
# imports — the exact transitive closure of Hydra.Sources.Kernel.Types.All, which
# ColdSeedMain uses as its JSON decode-universe context. Refreshed from
# packages/hydra-kernel/src/main/haskell by bin/cold-seed-dist-haskell.sh on every
# run. Generated artifact — never hand-edited, never committed.
typesmods/

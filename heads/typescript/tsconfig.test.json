{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": false,
    "rootDir": "../..",
    "outDir": "build/test",
    "noEmit": true
  },
  "include": [
    "src/main/typescript/**/*.ts",
    "src/test/typescript/**/*.ts",
    "../../dist/typescript/hydra-kernel/src/**/*.ts"
  ],
  "exclude": [
    "build",
    "node_modules",
    "src/main/typescript/hydra/bootstrap.ts",
    "../../dist/typescript/hydra-kernel/src/main/typescript/hydra/bootstrap.ts",
    // `libraries.ts` and the test/runtime modules import from generated
    // kernel paths (context.js, graph.js, …) that only exist after the
    // sync copies the hand-written runtime into dist/. The COPIES are
    // type-checked via the dist/typescript/hydra-kernel include path;
    // the src/ originals are excluded here so the dangling imports don't
    // produce TS2307. (bin/test-distribution.sh validates the dist
    // tree end-to-end.)
    "src/main/typescript/hydra/lib/libraries.ts",
    "src/test/typescript/hydra/test/**"
  ]
}

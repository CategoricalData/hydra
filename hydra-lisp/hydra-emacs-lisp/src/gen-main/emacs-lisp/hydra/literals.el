(defvar hydra_literals_float_value_to_bigfloat (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :bigfloat) (funcall (lambda (bf) bf) match_value)) ((equal (car match_target) :float32) (funcall (lambda (f32) (hydra_lib_literals_float32_to_bigfloat f32)) match_value)) ((equal (car match_target) :float64) (funcall (lambda (f64) (hydra_lib_literals_float64_to_bigfloat f64)) match_value)))) (cadr match_target))))


(defvar hydra_literals_bigfloat_to_float_value (lambda (ft) (lambda (bf) (funcall (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :bigfloat) (funcall (lambda (_) (list :bigfloat bf)) match_value)) ((equal (car match_target) :float32) (funcall (lambda (_) (list :float32 (hydra_lib_literals_bigfloat_to_float32 bf))) match_value)) ((equal (car match_target) :float64) (funcall (lambda (_) (list :float64 (hydra_lib_literals_bigfloat_to_float64 bf))) match_value)))) (cadr match_target))) ft))))


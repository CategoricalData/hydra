(require 'cl-lib)

(require 'hydra.ast)

(require 'hydra.core)

(require 'hydra.lib.lists)

(require 'hydra.lib.maybes)

(defvar hydra_encode_ast_associativity (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :none) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Associativity" (make-hydra_core_field "none" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :left) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Associativity" (make-hydra_core_field "left" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :right) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Associativity" (make-hydra_core_field "right" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :both) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Associativity" (make-hydra_core_field "both" (funcall (lambda (_) (list :unit nil)) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_ast_block_style (lambda (x) (list :record (make-hydra_core_record "hydra.ast.BlockStyle" (list (make-hydra_core_field "indent" (funcall (lambda (opt) (list :maybe (funcall (hydra_lib_maybes_map (lambda (x) (list :literal (list :string x)))) opt))) (funcall (lambda (v) (hydra_ast_block_style-indent v)) x))) (make-hydra_core_field "newlineBeforeContent" (funcall (lambda (x) (list :literal (list :boolean x))) (funcall (lambda (v) (hydra_ast_block_style-newline_before_content v)) x))) (make-hydra_core_field "newlineAfterContent" (funcall (lambda (x) (list :literal (list :boolean x))) (funcall (lambda (v) (hydra_ast_block_style-newline_after_content v)) x))))))))

(defvar hydra_encode_ast_symbol (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.ast.Symbol" (funcall (lambda (x) (list :literal (list :string x))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_ast_brackets (lambda (x) (list :record (make-hydra_core_record "hydra.ast.Brackets" (list (make-hydra_core_field "open" (hydra_encode_ast_symbol (funcall (lambda (v) (hydra_ast_brackets-open v)) x))) (make-hydra_core_field "close" (hydra_encode_ast_symbol (funcall (lambda (v) (hydra_ast_brackets-close v)) x))))))))

(defvar hydra_encode_ast_indent_style (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :all_lines) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.IndentStyle" (make-hydra_core_field "allLines" (funcall (lambda (x) (list :literal (list :string x))) y))))) match_value)) ((equal (car match_target) :subsequent_lines) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.IndentStyle" (make-hydra_core_field "subsequentLines" (funcall (lambda (x) (list :literal (list :string x))) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_ast_ws (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :none) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Ws" (make-hydra_core_field "none" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :space) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Ws" (make-hydra_core_field "space" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :break) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Ws" (make-hydra_core_field "break" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :break_and_indent) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Ws" (make-hydra_core_field "breakAndIndent" (funcall (lambda (x) (list :literal (list :string x))) y))))) match_value)) ((equal (car match_target) :double_break) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Ws" (make-hydra_core_field "doubleBreak" (funcall (lambda (_) (list :unit nil)) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_ast_padding (lambda (x) (list :record (make-hydra_core_record "hydra.ast.Padding" (list (make-hydra_core_field "left" (hydra_encode_ast_ws (funcall (lambda (v) (hydra_ast_padding-left v)) x))) (make-hydra_core_field "right" (hydra_encode_ast_ws (funcall (lambda (v) (hydra_ast_padding-right v)) x))))))))

(defvar hydra_encode_ast_precedence (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.ast.Precedence" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_ast_op (lambda (x) (list :record (make-hydra_core_record "hydra.ast.Op" (list (make-hydra_core_field "symbol" (hydra_encode_ast_symbol (funcall (lambda (v) (hydra_ast_op-symbol v)) x))) (make-hydra_core_field "padding" (hydra_encode_ast_padding (funcall (lambda (v) (hydra_ast_op-padding v)) x))) (make-hydra_core_field "precedence" (hydra_encode_ast_precedence (funcall (lambda (v) (hydra_ast_op-precedence v)) x))) (make-hydra_core_field "associativity" (hydra_encode_ast_associativity (funcall (lambda (v) (hydra_ast_op-associativity v)) x))))))))

(defvar hydra_encode_ast_bracket_expr (lambda (x) (list :record (make-hydra_core_record "hydra.ast.BracketExpr" (list (make-hydra_core_field "brackets" (hydra_encode_ast_brackets (funcall (lambda (v) (hydra_ast_bracket_expr-brackets v)) x))) (make-hydra_core_field "enclosed" (hydra_encode_ast_expr (funcall (lambda (v) (hydra_ast_bracket_expr-enclosed v)) x))) (make-hydra_core_field "style" (hydra_encode_ast_block_style (funcall (lambda (v) (hydra_ast_bracket_expr-style v)) x))))))))

(defvar hydra_encode_ast_expr (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :const) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Expr" (make-hydra_core_field "const" (hydra_encode_ast_symbol y))))) match_value)) ((equal (car match_target) :indent) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Expr" (make-hydra_core_field "indent" (hydra_encode_ast_indented_expression y))))) match_value)) ((equal (car match_target) :op) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Expr" (make-hydra_core_field "op" (hydra_encode_ast_op_expr y))))) match_value)) ((equal (car match_target) :brackets) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Expr" (make-hydra_core_field "brackets" (hydra_encode_ast_bracket_expr y))))) match_value)) ((equal (car match_target) :seq) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.ast.Expr" (make-hydra_core_field "seq" (hydra_encode_ast_seq_expr y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_ast_indented_expression (lambda (x) (list :record (make-hydra_core_record "hydra.ast.IndentedExpression" (list (make-hydra_core_field "style" (hydra_encode_ast_indent_style (funcall (lambda (v) (hydra_ast_indented_expression-style v)) x))) (make-hydra_core_field "expr" (hydra_encode_ast_expr (funcall (lambda (v) (hydra_ast_indented_expression-expr v)) x))))))))

(defvar hydra_encode_ast_op_expr (lambda (x) (list :record (make-hydra_core_record "hydra.ast.OpExpr" (list (make-hydra_core_field "op" (hydra_encode_ast_op (funcall (lambda (v) (hydra_ast_op_expr-op v)) x))) (make-hydra_core_field "lhs" (hydra_encode_ast_expr (funcall (lambda (v) (hydra_ast_op_expr-lhs v)) x))) (make-hydra_core_field "rhs" (hydra_encode_ast_expr (funcall (lambda (v) (hydra_ast_op_expr-rhs v)) x))))))))

(defvar hydra_encode_ast_seq_expr (lambda (x) (list :record (make-hydra_core_record "hydra.ast.SeqExpr" (list (make-hydra_core_field "op" (hydra_encode_ast_op (funcall (lambda (v) (hydra_ast_seq_expr-op v)) x))) (make-hydra_core_field "elements" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_ast_expr) xs))) (funcall (lambda (v) (hydra_ast_seq_expr-elements v)) x))))))))

(provide 'hydra.encode.ast)

(require 'cl-lib)

(require 'hydra.accessors)

(require 'hydra.core)

(require 'hydra.encode.core)

(require 'hydra.lib.lists)

(defvar hydra_encode_accessors_accessor_node (lambda (x) (list :record (make-hydra_core_record "hydra.accessors.AccessorNode" (list (make-hydra_core_field "name" (hydra_encode_core_name (funcall (lambda (v) (hydra_accessors_accessor_node-name v)) x))) (make-hydra_core_field "label" (funcall (lambda (x) (list :literal (list :string x))) (funcall (lambda (v) (hydra_accessors_accessor_node-label v)) x))) (make-hydra_core_field "id" (funcall (lambda (x) (list :literal (list :string x))) (funcall (lambda (v) (hydra_accessors_accessor_node-id v)) x))))))))

(defvar hydra_encode_accessors_term_accessor (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :annotated_body) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "annotatedBody" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :application_function) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "applicationFunction" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :application_argument) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "applicationArgument" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :lambda_body) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "lambdaBody" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :union_cases_default) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "unionCasesDefault" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :union_cases_branch) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "unionCasesBranch" (hydra_encode_core_name y))))) match_value)) ((equal (car match_target) :let_body) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "letBody" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :let_binding) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "letBinding" (hydra_encode_core_name y))))) match_value)) ((equal (car match_target) :list_element) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "listElement" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :map_key) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "mapKey" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :map_value) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "mapValue" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :maybe_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "maybeTerm" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :product_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "productTerm" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :record_field) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "recordField" (hydra_encode_core_name y))))) match_value)) ((equal (car match_target) :set_element) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "setElement" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :sum_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "sumTerm" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :type_lambda_body) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "typeLambdaBody" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :type_application_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "typeApplicationTerm" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :injection_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "injectionTerm" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :wrapped_term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.accessors.TermAccessor" (make-hydra_core_field "wrappedTerm" (funcall (lambda (_) (list :unit nil)) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_accessors_accessor_path (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.accessors.AccessorPath" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_accessors_term_accessor) xs))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_accessors_accessor_edge (lambda (x) (list :record (make-hydra_core_record "hydra.accessors.AccessorEdge" (list (make-hydra_core_field "source" (hydra_encode_accessors_accessor_node (funcall (lambda (v) (hydra_accessors_accessor_edge-source v)) x))) (make-hydra_core_field "path" (hydra_encode_accessors_accessor_path (funcall (lambda (v) (hydra_accessors_accessor_edge-path v)) x))) (make-hydra_core_field "target" (hydra_encode_accessors_accessor_node (funcall (lambda (v) (hydra_accessors_accessor_edge-target v)) x))))))))

(defvar hydra_encode_accessors_accessor_graph (lambda (x) (list :record (make-hydra_core_record "hydra.accessors.AccessorGraph" (list (make-hydra_core_field "nodes" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_accessors_accessor_node) xs))) (funcall (lambda (v) (hydra_accessors_accessor_graph-nodes v)) x))) (make-hydra_core_field "edges" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_accessors_accessor_edge) xs))) (funcall (lambda (v) (hydra_accessors_accessor_graph-edges v)) x))))))))

(provide 'hydra.encode.accessors)

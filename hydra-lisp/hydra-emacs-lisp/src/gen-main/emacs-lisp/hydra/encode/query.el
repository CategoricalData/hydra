(require 'cl-lib)

(require 'hydra.core)

(require 'hydra.encode.core)

(require 'hydra.lib.lists)

(require 'hydra.lib.maybes)

(require 'hydra.query)

(defvar hydra_encode_query_comparison_constraint (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :equal) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "equal" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :not_equal) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "notEqual" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :less_than) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "lessThan" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :greater_than) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "greaterThan" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :less_than_or_equal) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "lessThanOrEqual" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :greater_than_or_equal) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.ComparisonConstraint" (make-hydra_core_field "greaterThanOrEqual" (funcall (lambda (_) (list :unit nil)) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_edge (lambda (x) (list :record (make-hydra_core_record "hydra.query.Edge" (list (make-hydra_core_field "type" (hydra_encode_core_name (funcall (lambda (v) (hydra_query_edge-type v)) x))) (make-hydra_core_field "out" (funcall (lambda (opt) (list :maybe (funcall (hydra_lib_maybes_map hydra_encode_core_name) opt))) (funcall (lambda (v) (hydra_query_edge-out v)) x))) (make-hydra_core_field "in" (funcall (lambda (opt) (list :maybe (funcall (hydra_lib_maybes_map hydra_encode_core_name) opt))) (funcall (lambda (v) (hydra_query_edge-in v)) x))))))))

(defvar hydra_encode_query_variable (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.query.Variable" (funcall (lambda (x) (list :literal (list :string x))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_query_node (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :term) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Node" (make-hydra_core_field "term" (hydra_encode_core_term y))))) match_value)) ((equal (car match_target) :variable) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Node" (make-hydra_core_field "variable" (hydra_encode_query_variable y))))) match_value)) ((equal (car match_target) :wildcard) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Node" (make-hydra_core_field "wildcard" (funcall (lambda (_) (list :unit nil)) y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_range (lambda (x) (list :record (make-hydra_core_record "hydra.query.Range" (list (make-hydra_core_field "min" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) (funcall (lambda (v) (hydra_query_range-min v)) x))) (make-hydra_core_field "max" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) (funcall (lambda (v) (hydra_query_range-max v)) x))))))))

(defvar hydra_encode_query_regex_quantifier (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :one) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "one" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :zero_or_one) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "zeroOrOne" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :zero_or_more) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "zeroOrMore" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :one_or_more) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "oneOrMore" (funcall (lambda (_) (list :unit nil)) y))))) match_value)) ((equal (car match_target) :exactly) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "exactly" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :at_least) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "atLeast" (funcall (lambda (x) (list :literal (list :integer (list :int32 x)))) y))))) match_value)) ((equal (car match_target) :range) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.RegexQuantifier" (make-hydra_core_field "range" (hydra_encode_query_range y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_step (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :edge) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Step" (make-hydra_core_field "edge" (hydra_encode_query_edge y))))) match_value)) ((equal (car match_target) :project) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Step" (make-hydra_core_field "project" (hydra_encode_core_projection y))))) match_value)) ((equal (car match_target) :compare) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Step" (make-hydra_core_field "compare" (hydra_encode_query_comparison_constraint y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_path (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :step) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Path" (make-hydra_core_field "step" (hydra_encode_query_step y))))) match_value)) ((equal (car match_target) :regex) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Path" (make-hydra_core_field "regex" (hydra_encode_query_regex_sequence y))))) match_value)) ((equal (car match_target) :inverse) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Path" (make-hydra_core_field "inverse" (hydra_encode_query_path y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_regex_sequence (lambda (x) (list :record (make-hydra_core_record "hydra.query.RegexSequence" (list (make-hydra_core_field "path" (hydra_encode_query_path (funcall (lambda (v) (hydra_query_regex_sequence-path v)) x))) (make-hydra_core_field "quantifier" (hydra_encode_query_regex_quantifier (funcall (lambda (v) (hydra_query_regex_sequence-quantifier v)) x))))))))

(defvar hydra_encode_query_triple_pattern (lambda (x) (list :record (make-hydra_core_record "hydra.query.TriplePattern" (list (make-hydra_core_field "subject" (hydra_encode_query_node (funcall (lambda (v) (hydra_query_triple_pattern-subject v)) x))) (make-hydra_core_field "predicate" (hydra_encode_query_path (funcall (lambda (v) (hydra_query_triple_pattern-predicate v)) x))) (make-hydra_core_field "object" (hydra_encode_query_node (funcall (lambda (v) (hydra_query_triple_pattern-object v)) x))))))))

(defvar hydra_encode_query_graph_pattern (lambda (x) (list :record (make-hydra_core_record "hydra.query.GraphPattern" (list (make-hydra_core_field "graph" (hydra_encode_core_name (funcall (lambda (v) (hydra_query_graph_pattern-graph v)) x))) (make-hydra_core_field "patterns" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_query_pattern) xs))) (funcall (lambda (v) (hydra_query_graph_pattern-patterns v)) x))))))))

(defvar hydra_encode_query_pattern (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :triple) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Pattern" (make-hydra_core_field "triple" (hydra_encode_query_triple_pattern y))))) match_value)) ((equal (car match_target) :negation) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Pattern" (make-hydra_core_field "negation" (hydra_encode_query_pattern y))))) match_value)) ((equal (car match_target) :conjunction) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Pattern" (make-hydra_core_field "conjunction" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_query_pattern) xs))) y))))) match_value)) ((equal (car match_target) :disjunction) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Pattern" (make-hydra_core_field "disjunction" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_query_pattern) xs))) y))))) match_value)) ((equal (car match_target) :graph) (funcall (lambda (y) (list :union (make-hydra_core_injection "hydra.query.Pattern" (make-hydra_core_field "graph" (hydra_encode_query_graph_pattern y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_query_path_equation (lambda (x) (list :record (make-hydra_core_record "hydra.query.PathEquation" (list (make-hydra_core_field "left" (hydra_encode_query_path (funcall (lambda (v) (hydra_query_path_equation-left v)) x))) (make-hydra_core_field "right" (hydra_encode_query_path (funcall (lambda (v) (hydra_query_path_equation-right v)) x))))))))

(defvar hydra_encode_query_pattern_implication (lambda (x) (list :record (make-hydra_core_record "hydra.query.PatternImplication" (list (make-hydra_core_field "antecedent" (hydra_encode_query_pattern (funcall (lambda (v) (hydra_query_pattern_implication-antecedent v)) x))) (make-hydra_core_field "consequent" (hydra_encode_query_pattern (funcall (lambda (v) (hydra_query_pattern_implication-consequent v)) x))))))))

(defvar hydra_encode_query_query (lambda (x) (list :record (make-hydra_core_record "hydra.query.Query" (list (make-hydra_core_field "variables" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_query_variable) xs))) (funcall (lambda (v) (hydra_query_query-variables v)) x))) (make-hydra_core_field "patterns" (funcall (lambda (xs) (list :list (funcall (hydra_lib_lists_map hydra_encode_query_pattern) xs))) (funcall (lambda (v) (hydra_query_query-patterns v)) x))))))))

(provide 'hydra.encode.query)

(define-library (hydra encode parsing)
(export hydra_encode_parsing_parse_error hydra_encode_parsing_parse_success hydra_encode_parsing_parse_result)
(import (scheme base) (hydra core) (hydra parsing))
(begin
(define hydra_encode_parsing_parse_error (lambda (x) (list 'record (make-hydra_core_record "hydra.parsing.ParseError" (list (make-hydra_core_field "message" ((lambda (x2) (list 'literal (list 'string x2))) ((lambda (v) (hydra_parsing_parse_error-message v)) x))) (make-hydra_core_field "remainder" ((lambda (x2) (list 'literal (list 'string x2))) ((lambda (v) (hydra_parsing_parse_error-remainder v)) x))))))))
(define hydra_encode_parsing_parse_success (lambda (a) (lambda (x) (list 'record (make-hydra_core_record "hydra.parsing.ParseSuccess" (list (make-hydra_core_field "value" (a ((lambda (v) (hydra_parsing_parse_success-value v)) x))) (make-hydra_core_field "remainder" ((lambda (x2) (list 'literal (list 'string x2))) ((lambda (v) (hydra_parsing_parse_success-remainder v)) x)))))))))
(define hydra_encode_parsing_parse_result (lambda (a) (lambda (match_target) ((lambda (match_value) (cond ((equal? (car match_target) 'success) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.parsing.ParseResult" (make-hydra_core_field "success" ((hydra_encode_parsing_parse_success a) y))))) match_value)) ((equal? (car match_target) 'failure) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.parsing.ParseResult" (make-hydra_core_field "failure" (hydra_encode_parsing_parse_error y))))) match_value)))) (cadr match_target)))))))

(define-library (hydra show error core)
(export hydra_show_error_core_duplicate_binding_error hydra_show_error_core_duplicate_field_error hydra_show_error_core_invalid_term_error hydra_show_error_core_undefined_field_error hydra_show_error_core_undefined_term_error hydra_show_error_core_undefined_type_error hydra_show_error_core_unexpected_term_variant_error hydra_show_error_core_unexpected_type_variant_error)
(import (scheme base) (hydra core) (hydra error core) (hydra lib strings) (hydra show core) (hydra show meta))
(begin
(define hydra_show_error_core_duplicate_binding_error (lambda (e) (hydra_lib_strings_cat (list "duplicate binding: " ((lambda (v) v) ((lambda (v) (hydra_error_core_duplicate_binding_error-name v)) e))))))
(define hydra_show_error_core_duplicate_field_error (lambda (e) (hydra_lib_strings_cat (list "duplicate field: " ((lambda (v) v) ((lambda (v) (hydra_error_core_duplicate_field_error-name v)) e))))))
(define hydra_show_error_core_invalid_term_error (lambda (e) ((hydra_lib_strings_cat2 "invalid term: ") ((lambda (match_target) ((lambda (match_value) (cond ((equal? (car match_target) 'duplicate_binding) (hydra_show_error_core_duplicate_binding_error match_value)) ((equal? (car match_target) 'duplicate_field) (hydra_show_error_core_duplicate_field_error match_value)))) (cadr match_target))) e))))
(define hydra_show_error_core_undefined_field_error (lambda (e) (let ((fname ((lambda (v) (hydra_error_core_undefined_field_error-field_name v)) e))) (let ((tname ((lambda (v) (hydra_error_core_undefined_field_error-type_name v)) e))) (hydra_lib_strings_cat (list "no such field \"" ((lambda (v) v) fname) "\" in type \"" ((lambda (v) v) tname) "\""))))))
(define hydra_show_error_core_undefined_term_error (lambda (e) ((hydra_lib_strings_cat2 "undefined term: ") ((lambda (v) v) ((lambda (v) (hydra_error_core_undefined_term_error-name v)) e)))))
(define hydra_show_error_core_undefined_type_error (lambda (e) ((hydra_lib_strings_cat2 "undefined type: ") ((lambda (v) v) ((lambda (v) (hydra_error_core_undefined_type_error-name v)) e)))))
(define hydra_show_error_core_unexpected_term_variant_error (lambda (e) (let ((expected ((lambda (v) (hydra_error_core_unexpected_term_variant_error-expected_variant v)) e))) (let ((actual ((lambda (v) (hydra_error_core_unexpected_term_variant_error-actual_term v)) e))) (hydra_lib_strings_cat (list "expected " (hydra_show_meta_term_variant expected) " term but found " (hydra_show_core_term actual)))))))
(define hydra_show_error_core_unexpected_type_variant_error (lambda (e) (let ((expected ((lambda (v) (hydra_error_core_unexpected_type_variant_error-expected_variant v)) e))) (let ((actual ((lambda (v) (hydra_error_core_unexpected_type_variant_error-actual_type v)) e))) (hydra_lib_strings_cat (list "expected " (hydra_show_meta_type_variant expected) " type but found " (hydra_show_core_type actual)))))))))

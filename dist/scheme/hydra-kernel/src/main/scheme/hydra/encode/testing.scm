(define hydra_encode_testing_test_group (lambda (x) (list 'record (make-hydra_core_record "hydra.testing.TestGroup" (list (make-hydra_core_field "name" ((lambda (x2) (list 'literal (list 'string x2))) ((lambda (v) (hydra_testing_test_group-name v)) x))) (make-hydra_core_field "description" ((lambda (opt) (list 'maybe ((hydra_lib_maybes_map (lambda (x2) (list 'literal (list 'string x2)))) opt))) ((lambda (v) (hydra_testing_test_group-description v)) x))) (make-hydra_core_field "subgroups" ((lambda (xs) (list 'list ((hydra_lib_lists_map hydra_encode_testing_test_group) xs))) ((lambda (v) (hydra_testing_test_group-subgroups v)) x))) (make-hydra_core_field "cases" ((lambda (xs) (list 'list ((hydra_lib_lists_map hydra_encode_testing_test_case_with_metadata) xs))) ((lambda (v) (hydra_testing_test_group-cases v)) x))))))))))

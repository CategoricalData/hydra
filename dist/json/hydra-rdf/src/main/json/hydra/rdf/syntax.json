        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "Stand-in for rdfs:Class"}}}],
              "body": {"wrap": {"unit": {}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Dataset",

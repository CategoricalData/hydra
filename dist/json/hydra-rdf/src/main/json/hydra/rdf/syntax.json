          "body": {"wrap": {"set": {"variable": "hydra.rdf.syntax.Quad"}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Description",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A graph of RDF statements together with a distinguished subject and/or object node"}}}],
              "body": {
                "record": [
                  {"name": "subject", "type": {"variable": "hydra.rdf.syntax.Node"}},
                  {"name": "graph", "type": {"variable": "hydra.rdf.syntax.Graph"}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Graph",
        "type": {
          "body": {"wrap": {"set": {"variable": "hydra.rdf.syntax.Triple"}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Iri",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "An Internationalized Resource Identifier"}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.IriOrLiteral",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "An IRI or a literal; this type is a convenience for downstream models like SHACL which may exclude blank nodes"}}}],
              "body": {
                "union": [
                  {"name": "iri", "type": {"variable": "hydra.rdf.syntax.Iri"}},
                  {"name": "literal", "type": {"variable": "hydra.rdf.syntax.Literal"}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.LangStrings",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A convenience type which provides at most one string value per language, and optionally a value without a language"}}}],
              "body": {
                "wrap": {
                  "map": {
                    "keys": {"maybe": {"variable": "hydra.rdf.syntax.LanguageTag"}},
                    "values": {"literal": {"string": {}}}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.LanguageTag",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A BCP47 language tag"}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Literal",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A value such as a string, number, or date"}}}],
              "body": {
                "record": [
                  {
                    "name": "lexicalForm",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "a Unicode string, which should be in Normal Form C"}}}],
                        "body": {"literal": {"string": {}}}}}},
                  {
                    "name": "datatypeIri",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "an IRI identifying a datatype that determines how the lexical form maps to a literal value"}}}],
                        "body": {"variable": "hydra.rdf.syntax.Iri"}}}},
                  {
                    "name": "languageTag",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "An optional language tag, present if and only if the datatype IRI is http://www.w3.org/1999/02/22-rdf-syntax-ns#langString"}}}],
                        "body": {"maybe": {"variable": "hydra.rdf.syntax.LanguageTag"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Node",
        "type": {
          "body": {
            "union": [
              {"name": "iri", "type": {"variable": "hydra.rdf.syntax.Iri"}},
              {"name": "bnode", "type": {"variable": "hydra.rdf.syntax.BlankNode"}},
              {"name": "literal", "type": {"variable": "hydra.rdf.syntax.Literal"}}]},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Property",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A type representing an RDF property, and encapsulating its domain, range, and subclass relationships"}}}],
              "body": {
                "record": [
                  {
                    "name": "domain",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "State that any resource that has a given property is an instance of one or more classes"}}}],
                        "body": {"set": {"variable": "hydra.rdf.syntax.RdfsClass"}}}}},
                  {
                    "name": "range",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "States that the values of a property are instances of one or more classes"}}}],
                        "body": {"set": {"variable": "hydra.rdf.syntax.RdfsClass"}}}}},
                  {
                    "name": "subPropertyOf",
                    "type": {"set": {"variable": "hydra.rdf.syntax.Property"}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Quad",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {"string": "An RDF triple with an optional named graph component"}}}],
              "body": {
                "record": [
                  {"name": "subject", "type": {"variable": "hydra.rdf.syntax.Resource"}},
                  {"name": "predicate", "type": {"variable": "hydra.rdf.syntax.Iri"}},
                  {"name": "object", "type": {"variable": "hydra.rdf.syntax.Node"}},
                  {
                    "name": "graph",
                    "type": {"maybe": {"variable": "hydra.rdf.syntax.Iri"}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Resource",
        "type": {
          "body": {
            "union": [
              {"name": "iri", "type": {"variable": "hydra.rdf.syntax.Iri"}},
              {"name": "bnode", "type": {"variable": "hydra.rdf.syntax.BlankNode"}}]},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.rdf.syntax.Triple",
        "type": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "An RDF triple defined by a subject, predicate, and object"}}}],
              "body": {
                "record": [
                  {"name": "subject", "type": {"variable": "hydra.rdf.syntax.Resource"}},
                  {"name": "predicate", "type": {"variable": "hydra.rdf.syntax.Iri"}},
                  {"name": "object", "type": {"variable": "hydra.rdf.syntax.Node"}}]}}},
          "variables": []}}}],
  "description": "An RDF 1.1 syntax model",
  "namespace": "hydra.rdf.syntax",
  "termDependencies": ["hydra.core"],
  "typeDependencies": ["hydra.core"]}

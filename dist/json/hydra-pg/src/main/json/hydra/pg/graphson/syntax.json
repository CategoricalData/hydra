    {
      "type": {
        "name": "hydra.pg.graphson.syntax.Value",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "union": [
                  {"name": "bigDecimal", "type": {"variable": "hydra.pg.graphson.syntax.BigDecimalValue"}},
                  {"name": "bigInteger", "type": {"literal": {"integer": "bigint"}}},
                  {"name": "binary", "type": {"literal": "string"}},
                  {"name": "boolean", "type": {"literal": "boolean"}},
                  {"name": "byte", "type": {"literal": {"integer": "uint8"}}},
                  {"name": "char", "type": {"literal": {"integer": "uint32"}}},
                  {"name": "composite", "type": {"variable": "hydra.pg.graphson.syntax.CompositeTypedValue"}},
                  {"name": "dateTime", "type": {"variable": "hydra.pg.graphson.syntax.DateTime"}},
                  {"name": "double", "type": {"variable": "hydra.pg.graphson.syntax.DoubleValue"}},
                  {"name": "duration", "type": {"variable": "hydra.pg.graphson.syntax.Duration"}},
                  {"name": "float", "type": {"variable": "hydra.pg.graphson.syntax.FloatValue"}},
                  {"name": "integer", "type": {"literal": {"integer": "int32"}}},
                  {"name": "list", "type": {"list": {"variable": "hydra.pg.graphson.syntax.Value"}}},
                  {"name": "long", "type": {"literal": {"integer": "int64"}}},
                  {"name": "map", "type": {"variable": "hydra.pg.graphson.syntax.Map"}},
                  {"name": "null", "type": "unit"},
                  {"name": "primitive", "type": {"variable": "hydra.pg.graphson.syntax.PrimitiveTypedValue"}},
                  {"name": "set", "type": {"list": {"variable": "hydra.pg.graphson.syntax.Value"}}},
                  {"name": "short", "type": {"literal": {"integer": "int16"}}},
                  {"name": "string", "type": {"literal": "string"}},
                  {"name": "uuid", "type": {"variable": "hydra.pg.graphson.syntax.Uuid"}}]},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {"literal": {"string": "A GraphSON value, covering the subset of GraphSON value types this model supports"}}}]}}}}}},

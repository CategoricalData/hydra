{
  "name": "hydra.pg.graphson.syntax",
  "metadata": {
    "description": "A syntax model for TinkerPop's GraphSON format. This model is designed to be as inclusive as possible, supporting GraphSON 4.0 as well as earlier versions. See https://github.com/apache/tinkerpop/blob/master/docs/src/dev/io/graphson.asciidoc.",
    "comments": [],
    "seeAlso": []},
  "dependencies": [{"module": "hydra.core"}],
  "definitions": [
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.BigDecimalValue",
        "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.CompositeTypedValue",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "type", "type": {"variable": "hydra.pg.graphson.syntax.TypeName"}},
              {"name": "fields", "type": {"variable": "hydra.pg.graphson.syntax.Map"}}]}}}},
    {
      "type": {"name": "hydra.pg.graphson.syntax.DateTime", "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.DoubleValue",
        "body": {
          "variables": [],
          "body": {
            "union": [
              {"name": "finite", "type": {"literal": {"float": {"float64": {}}}}},
              {"name": "infinity", "type": {"unit": {}}},
              {"name": "negativeInfinity", "type": {"unit": {}}},
              {"name": "notANumber", "type": {"unit": {}}}]}}}},
    {
      "type": {"name": "hydra.pg.graphson.syntax.Duration", "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {"name": "hydra.pg.graphson.syntax.EdgeLabel", "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.FloatValue",
        "body": {
          "variables": [],
          "body": {
            "union": [
              {"name": "finite", "type": {"literal": {"float": {"float32": {}}}}},
              {"name": "infinity", "type": {"unit": {}}},
              {"name": "negativeInfinity", "type": {"unit": {}}},
              {"name": "notANumber", "type": {"unit": {}}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.Map",
        "body": {"variables": [], "body": {"wrap": {"list": {"variable": "hydra.pg.graphson.syntax.ValuePair"}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.AdjacentEdge",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "id", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
              {"name": "vertexId", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
              {
                "name": "properties",
                "type": {
                  "map": {"keys": {"variable": "hydra.pg.graphson.syntax.PropertyKey"}, "values": {"variable": "hydra.pg.graphson.syntax.Value"}}}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.PrimitiveTypedValue",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "type", "type": {"variable": "hydra.pg.graphson.syntax.TypeName"}},
              {"name": "value", "type": {"literal": {"string": {}}}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.PropertyKey",
        "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {"name": "hydra.pg.graphson.syntax.TypeName", "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {"name": "hydra.pg.graphson.syntax.Uuid", "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.Value",
        "body": {
          "variables": [],
          "body": {
            "union": [
              {"name": "bigDecimal", "type": {"variable": "hydra.pg.graphson.syntax.BigDecimalValue"}},
              {"name": "bigInteger", "type": {"literal": {"integer": {"bigint": {}}}}},
              {"name": "binary", "type": {"literal": {"string": {}}}},
              {"name": "boolean", "type": {"literal": {"boolean": {}}}},
              {"name": "byte", "type": {"literal": {"integer": {"uint8": {}}}}},
              {"name": "char", "type": {"literal": {"integer": {"uint32": {}}}}},
              {"name": "composite", "type": {"variable": "hydra.pg.graphson.syntax.CompositeTypedValue"}},
              {"name": "dateTime", "type": {"variable": "hydra.pg.graphson.syntax.DateTime"}},
              {"name": "double", "type": {"variable": "hydra.pg.graphson.syntax.DoubleValue"}},
              {"name": "duration", "type": {"variable": "hydra.pg.graphson.syntax.Duration"}},
              {"name": "float", "type": {"variable": "hydra.pg.graphson.syntax.FloatValue"}},
              {"name": "integer", "type": {"literal": {"integer": {"int32": {}}}}},
              {"name": "list", "type": {"list": {"variable": "hydra.pg.graphson.syntax.Value"}}},
              {"name": "long", "type": {"literal": {"integer": {"int64": {}}}}},
              {"name": "map", "type": {"variable": "hydra.pg.graphson.syntax.Map"}},
              {"name": "null", "type": {"unit": {}}},
              {"name": "primitive", "type": {"variable": "hydra.pg.graphson.syntax.PrimitiveTypedValue"}},
              {"name": "set", "type": {"list": {"variable": "hydra.pg.graphson.syntax.Value"}}},
              {"name": "short", "type": {"literal": {"integer": {"int16": {}}}}},
              {"name": "string", "type": {"literal": {"string": {}}}},
              {"name": "uuid", "type": {"variable": "hydra.pg.graphson.syntax.Uuid"}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.ValuePair",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "first", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
              {"name": "second", "type": {"variable": "hydra.pg.graphson.syntax.Value"}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.Vertex",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "id", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
              {"name": "label", "type": {"optional": {"variable": "hydra.pg.graphson.syntax.VertexLabel"}}},
              {
                "name": "inEdges",
                "type": {
                  "map": {
                    "keys": {"variable": "hydra.pg.graphson.syntax.EdgeLabel"},
                    "values": {"list": {"variable": "hydra.pg.graphson.syntax.AdjacentEdge"}}}}},
              {
                "name": "outEdges",
                "type": {
                  "map": {
                    "keys": {"variable": "hydra.pg.graphson.syntax.EdgeLabel"},
                    "values": {"list": {"variable": "hydra.pg.graphson.syntax.AdjacentEdge"}}}}},
              {
                "name": "properties",
                "type": {
                  "map": {
                    "keys": {"variable": "hydra.pg.graphson.syntax.PropertyKey"},
                    "values": {"list": {"variable": "hydra.pg.graphson.syntax.VertexPropertyValue"}}}}}]}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.VertexLabel",
        "body": {"variables": [], "body": {"wrap": {"literal": {"string": {}}}}}}},
    {
      "type": {
        "name": "hydra.pg.graphson.syntax.VertexPropertyValue",
        "body": {
          "variables": [],
          "body": {
            "record": [
              {"name": "id", "type": {"optional": {"variable": "hydra.pg.graphson.syntax.Value"}}},
              {"name": "value", "type": {"variable": "hydra.pg.graphson.syntax.Value"}}]}}}}]}

                            "annotation": {"map": [{"key": {"variable": "minLength"}, "value": {"literal": {"integer": {"int32": 1}}}}]}}}}}},
                  {
                    "name": "outEdges",
                    "type": {
                      "map": {
                        "keys": {"variable": "hydra.pg.graphson.syntax.EdgeLabel"},
                        "values": {
                          "annotated": {
                            "body": {"list": {"variable": "hydra.pg.graphson.syntax.AdjacentEdge"}},
                            "annotation": {"map": [{"key": {"variable": "minLength"}, "value": {"literal": {"integer": {"int32": 1}}}}]}}}}}},
                  {
                    "name": "properties",
                    "type": {
                      "map": {
                        "keys": {"variable": "hydra.pg.graphson.syntax.PropertyKey"},
                        "values": {
                          "annotated": {
                            "body": {"list": {"variable": "hydra.pg.graphson.syntax.VertexPropertyValue"}},
                            "annotation": {"map": [{"key": {"variable": "minLength"}, "value": {"literal": {"integer": {"int32": 1}}}}]}}}}}}]},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {"literal": {"string": "A GraphSON vertex, with its incident edges and properties"}}}]}}}}}},

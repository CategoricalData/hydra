          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "record": [
                  {"name": "id", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
                  {"name": "vertexId", "type": {"variable": "hydra.pg.graphson.syntax.Value"}},
                  {
                    "name": "properties",
                    "type": {
                      "map": {"keys": {"variable": "hydra.pg.graphson.syntax.PropertyKey"}, "values": {"variable": "hydra.pg.graphson.syntax.Value"}}}}]},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {"literal": {"string": "A GraphSON edge as referenced from an adjacent vertex, with its own properties"}}}]}}}}}},

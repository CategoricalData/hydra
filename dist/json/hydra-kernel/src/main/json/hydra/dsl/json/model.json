                      "annotation": {
                        "map": [
                          {
                            "key": {"variable": "description"},
                            "value": {
                              "literal": {
                                "string": "A JSON object as an ordered list of key/value pairs. The ordering preserves the declaration order of the record from which the object was encoded, rather than alphabetizing keys. As a consequence, equality of Value objects is order-sensitive: two objects with the same pairs in a different order are equal as JSON, but not as Hydra Values."}}}]}}}}},
              "isLazy": false}],

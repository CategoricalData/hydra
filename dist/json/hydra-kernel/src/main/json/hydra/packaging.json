              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The optional module name"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.ModuleName"}}}}},
                  {
                    "name": "local",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The local name"}}}],
                        "body": {"literal": {"string": {}}}}}}]}}},
          "variables": []}}},
    {

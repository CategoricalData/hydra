{
  "definitions": [
    {
      "type": {
        "name": "hydra.packaging.Definition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A definition, which may be either a term, type, or primitive definition"}}}],
              "body": {
                "union": [
                  {
                    "name": "term",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A term definition"}}}],
                        "body": {"variable": "hydra.packaging.TermDefinition"}}}},
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A type definition"}}}],
                        "body": {"variable": "hydra.packaging.TypeDefinition"}}}},
                  {
                    "name": "primitive",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A primitive definition"}}}],
                        "body": {"variable": "hydra.packaging.PrimitiveDefinition"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.FileExtension",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {"key": "description", "value": {"literal": {"string": "A file extension (without the dot), e.g. \"json\" or \"py\""}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.Module",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {"string": "A logical collection of elements in the same namespace, having dependencies on zero or more other modules"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The name of the module, which is also the common prefix for all element names in the module"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "description",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "An optional human-readable description of the module"}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "dependencies",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "Any modules which this module directly depends on"}}}],
                        "body": {"list": {"variable": "hydra.packaging.ModuleDependency"}}}}},
                  {
                    "name": "definitions",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The definitions in this module"}}}],
                        "body": {"list": {"variable": "hydra.packaging.Definition"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.ModuleDependency",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A dependency on another module, identified by its name and (optionally) the package which provides it. When the package is omitted, the resolver searches all packages in scope; a duplicate module name across packages is a resolution error which can be disambiguated by naming the intended package explicitly."}}}],
              "body": {
                "record": [
                  {
                    "name": "module",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the depended-on module"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "package",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The package providing the depended-on module, if disambiguation is required"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.PackageName"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.ModuleName",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "The unique name of a module; a prefix for the names of elements defined in the module."}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.Package",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A package, which is a named collection of modules with metadata and dependencies"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the package"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}},
                  {
                    "name": "description",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "An optional human-readable description of the package"}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "dependencies",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The packages which this package depends on"}}}],
                        "body": {"list": {"variable": "hydra.packaging.PackageDependency"}}}}},
                  {
                    "name": "modules",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The modules in this package"}}}],
                        "body": {"list": {"variable": "hydra.packaging.Module"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageDependency",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {"string": "A dependency on another package, identified by name and constrained by an optional version specifier"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the depended-on package"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}},
                  {
                    "name": "version",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The version-range constraint on the depended-on package"}}}],
                        "body": {"variable": "hydra.packaging.PackageVersionSpecifier"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageName",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "The unique name of a package, e.g. \"hydra-kernel\" or \"hydra-python\""}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageVersionSpecifier",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A specifier constraining acceptable versions of a depended-on package. Currently only the `any` (unit) specifier is defined; future variants such as `exact`, `caret`, and `range` may be added without breaking consumers of the `any` form."}}}],
              "body": {
                "union": [
                  {
                    "name": "any",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "Any version of the package satisfies the dependency"}}}],
                        "body": {"unit": {}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PrimitiveDefinition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A primitive definition: the universal, host-independent declarative metadata for a primitive, including name, signature, description, long-form specification, cross-references, totality and purity flags, version metadata, and an optional default implementation expressed as a Hydra term."}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the primitive"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "signature",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The signature of the primitive (always explicit, never inferred)"}}}],
                        "body": {"variable": "hydra.typing.TermSignature"}}}},
                  {
                    "name": "description",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "A concise, one-sentence human-readable description of the primitive"}}}],
                        "body": {"literal": {"string": {}}}}}},
                  {
                    "name": "comments",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "A detailed, host-independent specification of the primitive's behavior. Used to capture constraints, edge cases, and semantic choices (e.g. floating-point sentinel behavior, numeric narrowing arithmetic, complexity expectations) that are not yet promoted to structured fields."}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "seeAlso",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Names of related primitives, for navigation and documentation purposes."}}}],
                        "body": {"list": {"variable": "hydra.core.Name"}}}}},
                  {
                    "name": "isPure",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "Whether the primitive is pure (referentially transparent, no observable side effects). Defaults to true."}}}],
                        "body": {"literal": {"boolean": {}}}}}},
                  {
                    "name": "isTotal",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "Whether the primitive is total (terminates on every input of its declared type). Defaults to true."}}}],
                        "body": {"literal": {"boolean": {}}}}}},
                  {
                    "name": "availableSince",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {"key": "description", "value": {"literal": {"string": "The version in which the primitive was introduced, if known."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.Version"}}}}},
                  {
                    "name": "deprecatedSince",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The version in which the primitive was deprecated, if applicable."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.Version"}}}}},
                  {
                    "name": "defaultImplementation",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "An optional cross-compilable reference implementation of the primitive, expressed as a Hydra term. Used by interpreters lacking a native implementation and as a proof-friendly reference. Distinct from the per-host Primitive.implementation."}}}],
                        "body": {"maybe": {"variable": "hydra.core.Term"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.QualifiedName",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A qualified name consisting of an optional module name together with a mandatory local name"}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The optional module name"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.ModuleName"}}}}},
                  {
                    "name": "local",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The local name"}}}],
                        "body": {"literal": {"string": {}}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.TermDefinition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A term-level definition, including a name, a term, and an optional signature"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the term"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "term",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The term being defined"}}}],
                        "body": {"variable": "hydra.core.Term"}}}},
                  {
                    "name": "signature",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The optional signature of the term. When absent, the signature is to be inferred."}}}],
                        "body": {"maybe": {"variable": "hydra.typing.TermSignature"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.TypeDefinition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A type-level definition, including a name and the type scheme"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the type"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "typeScheme",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The type scheme being defined"}}}],
                        "body": {"variable": "hydra.core.TypeScheme"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.Version",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [{"key": "description", "value": {"literal": {"string": "A version string, e.g. \"0.15\" or \"1.0.0\"."}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}}],
  "dependencies": [{"module": "hydra.core"}, {"module": "hydra.typing"}],
  "description": "A model for Hydra namespaces, modules, and packages",
  "name": "hydra.packaging"}

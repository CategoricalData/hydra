      "type": {
        "name": "hydra.packaging.Definition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A definition, which may be either a term, type, or primitive definition"}}}],
              "body": {
                "union": [
                  {
                    "name": "term",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A term definition"}}}],
                        "body": {"variable": "hydra.packaging.TermDefinition"}}}},
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A type definition"}}}],
                        "body": {"variable": "hydra.packaging.TypeDefinition"}}}},
                  {
                    "name": "primitive",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A primitive definition"}}}],
                        "body": {"variable": "hydra.packaging.PrimitiveDefinition"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.DefinitionReference",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A typed reference to a definition: a type, a term, or a primitive, identified by name"}}}],
              "body": {
                "union": [
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a type definition, by name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "term",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a term definition, by name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "primitive",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a primitive definition, by name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.EntityLifecycle",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "Version-lifecycle milestones for a packaging entity. Each milestone is independently optional; further milestones (e.g. stableSince, removedSince) may be added without changing dependent types."}}}],
              "body": {
                "record": [
                  {
                    "name": "availableSince",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The version in which the entity was introduced, if known."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.Version"}}}}},
                  {
                    "name": "deprecatedSince",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The version in which the entity was deprecated, if applicable."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.Version"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.EntityMetadata",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "Documentation and lifecycle metadata attachable to a packaging entity (package, module, or definition). Bundling these fields in one type lets future metadata be added without changing the field shape of the entities that carry it."}}}],
              "body": {
                "record": [
                  {
                    "name": "description",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "An optional, concise one-line human-readable summary of the entity."}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "comments",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "Zero or more long-form prose paragraphs: cross-cutting semantic conventions, caveats, and references that would otherwise be repeated across the entity's constituents."}}}],
                        "body": {"list": {"literal": {"string": {}}}}}}},
                  {
                    "name": "seeAlso",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Typed cross-references to related entities, for navigation and documentation."}}}],
                        "body": {"list": {"variable": "hydra.packaging.EntityReference"}}}}},
                  {
                    "name": "lifecycle",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "Optional version-lifecycle milestones for the entity."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.EntityLifecycle"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.EntityReference",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A typed reference to a packaging entity: a package, a module, or a definition"}}}],
              "body": {
                "union": [
                  {
                    "name": "package",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a package, by name"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}},
                  {
                    "name": "module",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a module, by name"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "definition",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A reference to a definition (type, term, or primitive)"}}}],
                        "body": {"variable": "hydra.packaging.DefinitionReference"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.FileExtension",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {"key": "description", "value": {"literal": {"string": "A file extension (without the dot), e.g. \"json\" or \"py\""}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.Module",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {"string": "A logical collection of elements in the same namespace, having dependencies on zero or more other modules"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The name of the module, which is also the common prefix for all element names in the module"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "metadata",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {"key": "description", "value": {"literal": {"string": "Optional documentation and lifecycle metadata for the module"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.EntityMetadata"}}}}},
                  {
                    "name": "dependencies",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "Any modules which this module directly depends on"}}}],
                        "body": {"list": {"variable": "hydra.packaging.ModuleDependency"}}}}},
                  {
                    "name": "definitions",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The definitions in this module"}}}],
                        "body": {"list": {"variable": "hydra.packaging.Definition"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.ModuleDependency",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A dependency on another module, identified by its name and (optionally) the package which provides it. When the package is omitted, the resolver searches all packages in scope; a duplicate module name across packages is a resolution error which can be disambiguated by naming the intended package explicitly."}}}],
              "body": {
                "record": [
                  {
                    "name": "module",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the depended-on module"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "package",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The package providing the depended-on module, if disambiguation is required"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.PackageName"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.ModuleName",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "The unique name of a module; a prefix for the names of elements defined in the module."}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.Package",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "A package, which is a named collection of modules with metadata and dependencies"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the package"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}},
                  {
                    "name": "metadata",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Optional documentation and lifecycle metadata for the package"}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.EntityMetadata"}}}}},
                  {
                    "name": "dependencies",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The packages which this package depends on"}}}],
                        "body": {"list": {"variable": "hydra.packaging.PackageDependency"}}}}},
                  {
                    "name": "modules",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The modules in this package"}}}],
                        "body": {"list": {"variable": "hydra.packaging.Module"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageDependency",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {"string": "A dependency on another package, identified by name and constrained by an optional version specifier"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the depended-on package"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}},
                  {
                    "name": "version",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The version-range constraint on the depended-on package"}}}],
                        "body": {"variable": "hydra.packaging.PackageVersionSpecifier"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageName",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "The unique name of a package, e.g. \"hydra-kernel\" or \"hydra-python\""}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PackageVersionSpecifier",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A specifier constraining acceptable versions of a depended-on package. Currently only the `any` (unit) specifier is defined; future variants such as `exact`, `caret`, and `range` may be added without breaking consumers of the `any` form."}}}],
              "body": {
                "union": [
                  {
                    "name": "any",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "Any version of the package satisfies the dependency"}}}],
                        "body": {"unit": {}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.packaging.PrimitiveDefinition",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A primitive definition: the universal, host-independent declarative metadata for a primitive, including name, signature, documentation and lifecycle metadata, totality and purity flags, and an optional default implementation expressed as a Hydra term."}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the primitive"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "signature",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The signature of the primitive (always explicit, never inferred)"}}}],
                        "body": {"variable": "hydra.typing.TermSignature"}}}},
                  {
                    "name": "metadata",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "Optional documentation and lifecycle metadata for the primitive (description, long-form comments, cross-references, version milestones)."}}}],
                        "body": {"maybe": {"variable": "hydra.packaging.EntityMetadata"}}}}},
                  {
                    "name": "isPure",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "Whether the primitive is pure (referentially transparent, no observable side effects). Defaults to true."}}}],
                        "body": {"literal": {"boolean": {}}}}}},
                  {
                    "name": "isTotal",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "Whether the primitive is total (terminates on every input of its declared type). Defaults to true."}}}],
                        "body": {"literal": {"boolean": {}}}}}},
                  {
                    "name": "defaultImplementation",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "An optional cross-compilable reference implementation of the primitive, expressed as a Hydra term. Used by interpreters lacking a native implementation and as a proof-friendly reference. Distinct from the per-host Primitive.implementation."}}}],
                        "body": {"maybe": {"variable": "hydra.core.Term"}}}}}]}}},
          "variables": []}}},
    {

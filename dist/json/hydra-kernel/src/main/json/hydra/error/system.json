{
  "name": "hydra.error.system",
  "metadata": {"description": "System-call error types", "comments": [], "seeAlso": []},
  "dependencies": [{"module": "hydra.file"}],
  "definitions": [
    {
      "type": {
        "name": "hydra.error.system.SystemError",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "union": [
                  {
                    "name": "commandNotFound",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.file.FilePath"},
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {
                                "literal": {
                                  "string": "POSIX ENOENT: the executable named by Command.program does not exist or is not found on PATH. Reported by the exec family (XSH, https://pubs.opengroup.org/onlinepubs/9799919799/functions/execve.html)"}}}]}}}},
                  {
                    "name": "permissionDenied",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.file.FilePath"},
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {
                                "literal": {"string": "POSIX EACCES: the executable exists but is not executable, or a path component denies search permission"}}}]}}}},
                  {
                    "name": "invalidWorkingDirectory",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.file.FilePath"},
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {"literal": {"string": "POSIX ENOENT or ENOTDIR raised by the implied chdir() to Command.workingDirectory"}}}]}}}},
                  {
                    "name": "interrupted",
                    "type": {
                      "annotated": {
                        "body": "unit",
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {
                                "literal": {
                                  "string": "The call was interrupted before the child produced a result (a portable abstraction over POSIX EINTR and host-level kills); the child's disposition is unknown"}}}]}}}},
                  {
                    "name": "other",
                    "type": {
                      "annotated": {
                        "body": {"literal": "string"},
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {
                                "literal": {
                                  "string": "Any other failure, carrying the host-provided error message verbatim (covers errno values not modeled above, such as EMFILE, ENOMEM, or E2BIG)"}}}]}}}}]},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {
                      "literal": {
                        "string": "A recoverable failure to launch a process or to perform a hydra.lib.system system call, named after the POSIX errno values the host reports. A child that launches successfully and then exits non-zero is not a SystemError; it is a ProcessResult with a non-zero exitCode"}}}]}}}}}}]}

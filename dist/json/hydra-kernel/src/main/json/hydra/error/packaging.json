{
  "definitions": [
    {
      "type": {
        "name": "hydra.error.packaging.ConflictingModuleNamespaceError",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A module namespace which, when mapped to a target language's directory or package structure, conflicts with another module's mapped namespace. For example, hydra.foo.bar and hydra.fooBar might both map to the same directory in a case-insensitive filesystem."}}}],
              "body": {
                "record": [
                  {
                    "name": "first",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The first module namespace"}}}],
                        "body": {"variable": "hydra.packaging.Namespace"}}}},
                  {
                    "name": "second",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "The second module namespace that conflicts with the first"}}}],
                        "body": {"variable": "hydra.packaging.Namespace"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.error.packaging.ConflictingVariantNameError",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A union type variant name which, when capitalized and concatenated with its type name, conflicts with another type definition name. For example, a union type Foo with a variant bar produces FooBar, which conflicts with an existing type definition FooBar. This is currently a problem only for the Haskell target."}}}],
              "body": {
                "record": [
                  {
                    "name": "namespace",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "The namespace of the module containing the conflict"}}}],
                        "body": {"variable": "hydra.packaging.Namespace"}}}},
                  {
                    "name": "typeName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The name of the union type"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "variantName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "The name of the variant field causing the conflict"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "conflictingName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "The name of the other type definition that conflicts with the generated constructor name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.error.packaging.DefinitionNotInModuleNamespaceError",
        "typeScheme": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A definition whose name does not have the module's namespace as a prefix. If the module namespace is foo.bar, all definition names must have the form foo.bar.quux."}}}],
              "body": {
                "record": [
                  {
                    "name": "namespace",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The namespace of the module"}}}],
                        "body": {"variable": "hydra.packaging.Namespace"}}}},
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {
                                "string": "The definition name that does not match the module namespace"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []}}},
    {

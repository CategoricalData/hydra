      "type": {
        "name": "hydra.error.packaging.ConflictingModuleNameError",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "record": [
                  {
                    "name": "first",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.packaging.ModuleName"},
                        "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "The first module name"}}}]}}}},
                  {
                    "name": "second",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.packaging.ModuleName"},
                        "annotation": {
                          "map": [
                            {
                              "key": {"variable": "description"},
                              "value": {"literal": {"string": "The second module name that conflicts with the first"}}}]}}}}]},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {
                      "literal": {
                        "string": "A module name which, when mapped to a target language's directory or package structure, conflicts with another module's mapped name. For example, hydra.foo.bar and hydra.fooBar might both map to the same directory in a case-insensitive filesystem."}}}]}}}}}},

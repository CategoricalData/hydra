{
  "definitions": [
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A module name which, when mapped to a target language's directory or package structure, conflicts with another module's mapped name. For example, hydra.foo.bar and hydra.fooBar might both map to the same directory in a case-insensitive filesystem."}}}],
              "body": {
                "record": [
                  {
                    "name": "first",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The first module name"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "second",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The second module name that conflicts with the first"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.ConflictingModuleNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A union type variant name which, when capitalized and concatenated with its type name, conflicts with another type definition name. For example, a union type Foo with a variant bar produces FooBar, which conflicts with an existing type definition FooBar. This is currently a problem only for the Haskell target."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the module containing the conflict"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "typeName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the union type"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "variantName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the variant field causing the conflict"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "conflictingName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The name of the other type definition that conflicts with the generated constructor name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.ConflictingVariantNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A definition whose name does not have the module's name as a prefix. If the module name is foo.bar, all definition names must have the form foo.bar.quux."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the module"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The definition name that does not match the module name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.DefinitionNotInModuleNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "Two consecutive definitions in a module's definitions list that are not in alphabetical order by local name. Hydra requires definitions to appear in lexicographic ASCII order of their local names."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {"key": "description", "value": {"literal": {"string": "The name of the module containing the misordered definitions"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "precedingName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The definition that appears first in the list"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "followingName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The definition that appears next, but should sort earlier than precedingName"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.DefinitionsOutOfOrderError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {"literal": {"string": "Two or more definitions in the same module share the same name"}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the module containing the duplicates"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The duplicated definition name"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.DuplicateDefinitionNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {"key": "description", "value": {"literal": {"string": "Two or more modules in the same package share the same name"}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The duplicated module name"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.DuplicateModuleNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A definition whose local name does not match the expected naming convention. Term-level definitions must be camelCase; type-level definitions must be PascalCase."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the module containing the definition"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The definition name that violates the naming convention"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "expectedConvention",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "The case convention the name should have followed (camel for term-level, pascal for type-level)"}}}],
                        "body": {"variable": "hydra.util.CaseConvention"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.InvalidDefinitionNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [{"key": "description", "value": {"literal": {"string": "An error indicating that a module is invalid"}}}],
              "body": {
                "union": [
                  {
                    "name": "conflictingVariantName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {
                              "literal": {"string": "A union variant name that conflicts with another type definition when mapped to a target language"}}}],
                        "body": {"variable": "hydra.error.packaging.ConflictingVariantNameError"}}}},
                  {
                    "name": "definitionNotInModuleName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "A definition whose name does not have the module's name as a prefix"}}}],
                        "body": {"variable": "hydra.error.packaging.DefinitionNotInModuleNameError"}}}},
                  {
                    "name": "definitionsOutOfOrder",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Two consecutive definitions in the definitions list that are not in alphabetical order"}}}],
                        "body": {"variable": "hydra.error.packaging.DefinitionsOutOfOrderError"}}}},
                  {
                    "name": "duplicateDefinitionName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Two or more definitions in the same module share the same name"}}}],
                        "body": {"variable": "hydra.error.packaging.DuplicateDefinitionNameError"}}}},
                  {
                    "name": "invalidDefinitionName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "A definition whose local name does not match the expected naming convention"}}}],
                        "body": {"variable": "hydra.error.packaging.InvalidDefinitionNameError"}}}},
                  {
                    "name": "invalidModuleNameConvention",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "A module whose name does not match the module-name naming convention"}}}],
                        "body": {"variable": "hydra.error.packaging.InvalidModuleNameConventionError"}}}},
                  {
                    "name": "missingDocumentation",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A top-level definition lacking a description annotation"}}}],
                        "body": {"variable": "hydra.error.packaging.MissingDocumentationError"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.InvalidModuleError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A module whose name does not match the dotted-lowercase naming convention. Module names must be dot-separated lowercase segments, each starting with a letter, e.g. hydra.core or hydra.lib.lists."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The module name that violates the convention"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.InvalidModuleNameConventionError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [{"key": "description", "value": {"literal": {"string": "An error indicating that a package is invalid"}}}],
              "body": {
                "union": [
                  {
                    "name": "conflictingModuleName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "Two module names that conflict when mapped to a target language"}}}],
                        "body": {"variable": "hydra.error.packaging.ConflictingModuleNameError"}}}},
                  {
                    "name": "duplicateModuleName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {"key": "description", "value": {"literal": {"string": "Two or more modules in the same package share the same name"}}}],
                        "body": {"variable": "hydra.error.packaging.DuplicateModuleNameError"}}}},
                  {
                    "name": "invalidModule",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "A module within the package is invalid"}}}],
                        "body": {"variable": "hydra.error.packaging.InvalidModuleError"}}}},
                  {
                    "name": "invalidPackageName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "A package whose name does not match the package-name naming convention"}}}],
                        "body": {"variable": "hydra.error.packaging.InvalidPackageNameError"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.InvalidPackageError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A package whose name does not match the hyphen-separated lowercase naming convention. Package names must be hyphen-separated lowercase segments, each starting with a letter, e.g. hydra-kernel or hydra-python."}}}],
              "body": {
                "record": [
                  {
                    "name": "packageName",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The package name that violates the convention"}}}],
                        "body": {"variable": "hydra.packaging.PackageName"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.InvalidPackageNameError"}},
    {
      "type": {
        "body": {
          "body": {
            "annotated": {
              "annotation": [
                {
                  "key": "description",
                  "value": {
                    "literal": {
                      "string": "A top-level definition whose term (or type, for type definitions) lacks a description annotation. Every definition in a Hydra module is expected to be wrapped in a doc \"...\" annotation at its top level."}}}],
              "body": {
                "record": [
                  {
                    "name": "moduleName",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "key": "description",
                            "value": {"literal": {"string": "The name of the module containing the undocumented definition"}}}],
                        "body": {"variable": "hydra.packaging.ModuleName"}}}},
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [{"key": "description", "value": {"literal": {"string": "The name of the undocumented definition"}}}],
                        "body": {"variable": "hydra.core.Name"}}}}]}}},
          "variables": []},
        "name": "hydra.error.packaging.MissingDocumentationError"}}],
  "dependencies": [{"module": "hydra.core"}, {"module": "hydra.packaging"}, {"module": "hydra.util"}],
  "metadata": {"comments": [], "description": "Error types for module and package validation", "seeAlso": []},
  "name": "hydra.error.packaging"}

          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "union": [
                  {
                    "name": "mapping",
                    "type": {
                      "annotated": {
                        "body": {"map": {"keys": {"variable": "hydra.yaml.model.Node"}, "values": {"variable": "hydra.yaml.model.Node"}}},
                        "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "A mapping from nodes to nodes"}}}]}}}},
                  {
                    "name": "scalar",
                    "type": {
                      "annotated": {
                        "body": {"variable": "hydra.yaml.model.Scalar"},
                        "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "A scalar value"}}}]}}}},
                  {
                    "name": "sequence",

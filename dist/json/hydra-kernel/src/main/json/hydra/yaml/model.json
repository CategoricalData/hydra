                      "annotated": {
                        "body": {"list": {"variable": "hydra.yaml.model.Node"}},
                        "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "A sequence of nodes"}}}]}}}}]},
              "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "A YAML node (value)"}}}]}}}}}},
    {

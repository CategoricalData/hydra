{
  "name": "hydra.yaml.model",
  "metadata": {
    "description": "A basic YAML representation model. Based on:\n  https://yaml.org/spec/1.2/spec.html\nThe Serialization and Presentation properties of YAML,\nincluding directives, comments, anchors, style, formatting, and aliases, are not supported by this model.\nIn addition, tags are omitted from this model, and non-standard scalars are unsupported.",
    "comments": [],
    "seeAlso": []},
  "dependencies": [{"module": "hydra.core"}],

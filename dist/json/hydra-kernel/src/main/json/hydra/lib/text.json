  "definitions": [
    {
      "primitive": {
        "name": "hydra.lib.text.decodeUtf8",
        "metadata": {
          "description": "Decode a sequence of bytes as UTF-8 text.",
          "comments": [
            "decodeUtf8(bytes) attempts to interpret bytes as a UTF-8 encoded string. A byte sequence which is not valid UTF-8 yields left(message), where message is a host-provided description of the decoding failure; a successful decode yields right(text).",
            "Pairs with hydra.lib.files.readFile, which returns raw bytes."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [],
          "parameters": [{"name": "arg0", "type": {"literal": "binary"}, "isLazy": false}],
          "result": {"type": {"either": {"left": {"literal": "string"}, "right": {"literal": "string"}}}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.text.encodeUtf8",
        "metadata": {
          "description": "Encode text as a sequence of UTF-8 bytes.",
          "comments": [
            "encodeUtf8(text) returns the UTF-8 encoding of text as raw bytes. Total: every Hydra string is valid Unicode and therefore always encodes.",
            "Pairs with hydra.lib.files.writeFile, which expects raw bytes."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [],
          "parameters": [{"name": "arg0", "type": {"literal": "string"}, "isLazy": false}],
          "result": {"type": {"literal": "binary"}}},
        "isPure": true,
        "isTotal": true}}]}

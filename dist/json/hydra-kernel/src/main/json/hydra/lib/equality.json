  "definitions": [
    {
      "primitive": {
        "name": "hydra.lib.equality.equal",
        "metadata": {
          "description": "Check whether two values are equal.",
          "comments": [
            "equal(x, y) returns true if x and y are structurally equal under the type's notion of equality.",
            "Requires an 'equality' type-class constraint on the argument type, which is the closest Hydra equivalent to Haskell's Eq instance.",
            "Equality is reflexive, symmetric, and transitive (no NaN-style exception on floating-point: floating-point equality is provided per the underlying host's IEEE 754 comparison rules, so NaN /= NaN at the level of float64/float32).",
            "Total. Corresponds to Haskell's (==) :: Eq a => a -> a -> Bool."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": [{"simple": "equality"}]}],
          "parameters": [
            {"name": "x", "description": "the first value to compare", "type": {"variable": "x"}, "isLazy": false},
            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"literal": "boolean"}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.equality.notEqual",
        "metadata": {
          "description": "Check whether two values are unequal.",
          "comments": [
            "notEqual(x, y) = logic.not(equal(x, y)); this defining equation is the specification, and the default implementation.",
            "Requires an 'equality' type-class constraint on the argument type.",
            "Total. Corresponds to Haskell's (/=) :: Eq a => a -> a -> Bool."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": [{"simple": "equality"}]}],
          "parameters": [
            {"name": "x", "description": "the first value to compare", "type": {"variable": "x"}, "isLazy": false},
            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"literal": "boolean"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {
          "lambda": {
            "parameter": "x",
            "body": {
              "lambda": {
                "parameter": "y",
                "body": {
                  "application": {
                    "function": {"variable": "hydra.lib.logic.not"},
                    "argument": {
                      "application": {
                        "function": {"application": {"function": {"variable": "hydra.lib.equality.equal"}, "argument": {"variable": "x"}}},
                        "argument": {"variable": "y"}}}}}}}}}}}]}

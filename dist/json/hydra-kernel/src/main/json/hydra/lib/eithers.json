                                        "parameter": "x"}},
                                    "function": {"variable": "hydra.lib.eithers.either"}}}}}}},
                        "parameter": "e"}},
                    "parameter": "g"}},
                "parameter": "f"}}}},
        "description": "Map over both sides of an either value.",

                                "function": {"variable": "hydra.lib.eithers.either"}}}}}}},
                    "parameter": "f"}},
                "parameter": "e"}}}},
        "description": "Bind (flatMap) for either: if Right, apply the function; if Left, return unchanged.",
        "isPure": true,
        "isTotal": true,
        "name": "hydra.lib.eithers.bind",
        "seeAlso": [],
        "signature": {

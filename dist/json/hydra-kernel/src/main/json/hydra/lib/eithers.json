            {"isLazy": false, "name": "arg1", "type": {"variable": "x"}},
            {"isLazy": false, "name": "arg2", "type": {"list": {"variable": "y"}}}],
          "result": {"type": {"either": {"left": {"variable": "z"}, "right": {"variable": "x"}}}},
          "typeParameters": [{"constraints": [], "name": "x"}, {"constraints": [], "name": "y"}, {"constraints": [], "name": "z"}]}}},

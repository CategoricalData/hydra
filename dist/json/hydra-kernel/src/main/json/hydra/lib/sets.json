            {"name": "arg0", "type": {"variable": "x"}, "isLazy": false},
            {"name": "arg1", "type": {"set": {"variable": "x"}}, "isLazy": false}],
          "result": {"type": {"set": {"variable": "x"}}}},
        "isPure": true,
        "isTotal": true}},

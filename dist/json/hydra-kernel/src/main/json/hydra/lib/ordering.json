            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"variable": "x"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {
          "lambda": {

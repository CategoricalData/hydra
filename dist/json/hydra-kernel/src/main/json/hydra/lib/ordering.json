  "definitions": [
    {
      "primitive": {
        "name": "hydra.lib.ordering.compare",
        "metadata": {
          "description": "Compare two values and return a Comparison.",
          "comments": [
            "compare(x, y) returns the hydra.util.Comparison value that classifies the relationship between x and y under the type's ordering: LessThan if x < y, EqualTo if x == y, GreaterThan if x > y.",
            "The result type's three-valued tag is the canonical primitive comparison; the boolean comparators (lt/lte/gt/gte) are derivable from it.",
            "Requires an 'ordering' type-class constraint on the argument type, which is the closest Hydra equivalent to Haskell's Ord instance.",
            "Since: 0.18 (moved from hydra.lib.equality.compare).",
            "Total. Corresponds to Haskell's compare :: Ord a => a -> a -> Ordering."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": [{"simple": "ordering"}]}],
          "parameters": [
            {"name": "x", "description": "the first value to compare", "type": {"variable": "x"}, "isLazy": false},
            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"variable": "hydra.util.Comparison"}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.ordering.gt",
        "metadata": {
          "description": "Check whether the first value is greater than the second.",
          "comments": [
            "gt(x, y) returns true iff x > y under the type's ordering.",
            "Requires an 'ordering' constraint on the argument type.",
            "Since: 0.18 (moved from hydra.lib.equality.gt).",
            "Total. Corresponds to Haskell's (>) :: Ord a => a -> a -> Bool."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": [{"simple": "ordering"}]}],
          "parameters": [
            {"name": "x", "description": "the first value to compare", "type": {"variable": "x"}, "isLazy": false},
            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"literal": "boolean"}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.ordering.gte",
        "metadata": {
          "description": "Check whether the first value is greater than or equal to the second.",
          "comments": [
            "gte(x, y) returns true iff x >= y under the type's ordering.",
            "Requires an 'ordering' constraint on the argument type.",
            "Since: 0.18 (moved from hydra.lib.equality.gte).",
            "Total. Corresponds to Haskell's (>=) :: Ord a => a -> a -> Bool."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": [{"simple": "ordering"}]}],
          "parameters": [
            {"name": "x", "description": "the first value to compare", "type": {"variable": "x"}, "isLazy": false},
            {"name": "y", "description": "the second value to compare", "type": {"variable": "x"}, "isLazy": false}],
          "result": {"type": {"literal": "boolean"}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.ordering.lt",
        "metadata": {
          "description": "Check whether the first value is less than the second.",
          "comments": [
            "lt(x, y) returns true iff x < y under the type's ordering.",

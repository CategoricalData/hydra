  "definitions": [
    {
      "primitive": {
        "name": "hydra.lib.functions.compose",
        "metadata": {
          "description": "Compose two functions.",
          "comments": [
            "compose(g, f, x) = g(f(x)); this defining equation is the specification.",
            "The outer function comes first: f is applied to x, and g is applied to the result.",
            "This is ordinary function composition, distinct from the Kleisli compose primitives of the monad modules.",
            "Total. Corresponds to Haskell's (.) :: (b -> c) -> (a -> b) -> a -> c."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "t1", "constraints": []}, {"name": "t2", "constraints": []}, {"name": "t3", "constraints": []}],
          "parameters": [
            {
              "name": "g",
              "description": "the outer function, applied to the result of f",
              "type": {"function": {"domain": {"variable": "t2"}, "codomain": {"variable": "t3"}}},
              "isLazy": false},
            {
              "name": "f",
              "description": "the inner function, applied to x first",
              "type": {"function": {"domain": {"variable": "t1"}, "codomain": {"variable": "t2"}}},
              "isLazy": false},
            {"name": "x", "description": "the argument to which f is applied", "type": {"variable": "t1"}, "isLazy": false}],
          "result": {"type": {"variable": "t3"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {
          "lambda": {
            "parameter": "g",
            "body": {
              "lambda": {
                "parameter": "f",
                "body": {
                  "lambda": {
                    "parameter": "x",
                    "body": {
                      "application": {
                        "function": {"variable": "g"},
                        "argument": {"application": {"function": {"variable": "f"}, "argument": {"variable": "x"}}}}}}}}}}}}},
    {
      "primitive": {
        "name": "hydra.lib.functions.const",
        "metadata": {
          "description": "Return the first argument, ignoring the second.",
          "comments": [
            "const(x, y) = x; this defining equation is the specification.",
            "Partially applied, const(x) is the constant function which returns x on every input.",
            "Total. Corresponds to Haskell's const :: a -> b -> a."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "t1", "constraints": []}, {"name": "t2", "constraints": []}],
          "parameters": [
            {"name": "x", "description": "the value to return", "type": {"variable": "t1"}, "isLazy": false},
            {"name": "y", "description": "the ignored second argument", "type": {"variable": "t2"}, "isLazy": false}],
          "result": {"type": {"variable": "t1"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {"lambda": {"parameter": "x", "body": {"lambda": {"parameter": "y", "body": {"variable": "x"}}}}}}},
    {
      "primitive": {
        "name": "hydra.lib.functions.flip",
        "metadata": {
          "description": "Swap the argument order of a binary function.",
          "comments": [
            "flip(f, x, y) = f(y, x); this defining equation is the specification.",
            "Total. Corresponds to Haskell's flip :: (a -> b -> c) -> b -> a -> c."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "t1", "constraints": []}, {"name": "t2", "constraints": []}, {"name": "t3", "constraints": []}],
          "parameters": [
            {
              "name": "f",
              "description": "the binary function whose argument order is swapped",
              "type": {
                "function": {"domain": {"variable": "t1"}, "codomain": {"function": {"domain": {"variable": "t2"}, "codomain": {"variable": "t3"}}}}},
              "isLazy": false},
            {"name": "x", "description": "the argument passed as f's second argument", "type": {"variable": "t2"}, "isLazy": false},
            {"name": "y", "description": "the argument passed as f's first argument", "type": {"variable": "t1"}, "isLazy": false}],
          "result": {"type": {"variable": "t3"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {
          "lambda": {
            "parameter": "f",
            "body": {
              "lambda": {
                "parameter": "x",
                "body": {
                  "lambda": {
                    "parameter": "y",
                    "body": {
                      "application": {
                        "function": {"application": {"function": {"variable": "f"}, "argument": {"variable": "y"}}},
                        "argument": {"variable": "x"}}}}}}}}}}},
    {
      "primitive": {
        "name": "hydra.lib.functions.identity",
        "metadata": {
          "description": "Return the argument unchanged.",
          "comments": [
            "identity(x) = x; this defining equation is the specification. The polymorphic identity function.",
            "identity is the unit of compose: compose(identity, f) and compose(f, identity) are both f.",
            "Total. Corresponds to Haskell's id :: a -> a."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "t1", "constraints": []}],
          "parameters": [{"name": "x", "description": "the value to return unchanged", "type": {"variable": "t1"}, "isLazy": false}],
          "result": {"type": {"variable": "t1"}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {"lambda": {"parameter": "x", "body": {"variable": "x"}}}}}]}

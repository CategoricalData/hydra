              "type": {"map": {"keys": {"variable": "k"}, "values": {"variable": "v"}}},
              "isLazy": false},
            {
              "name": "m2",
              "description": "the map whose keys are subtracted",
              "type": {"map": {"keys": {"variable": "k"}, "values": {"variable": "v"}}},
              "isLazy": false}],

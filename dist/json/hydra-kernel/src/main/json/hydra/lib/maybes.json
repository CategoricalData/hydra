                "body": {
                  "lambda": {
                    "body": {
                      "application": {
                        "argument": {
                          "lambda": {
                            "body": {
                              "application": {
                                "argument": {"variable": "mx"},
                                "function": {
                                  "application": {
                                    "argument": {"lambda": {"body": {"application": {"argument": {"variable": "x"}, "function": {"variable": "f"}}}, "parameter": "x"}},
                                    "function": {"variable": "hydra.lib.maybes.map"}}}}},
                            "parameter": "f"}},
                        "function": {"application": {"argument": {"variable": "mf"}, "function": {"variable": "hydra.lib.maybes.bind"}}}}},
                    "parameter": "mx"}},
                "parameter": "mf"}}}},
        "description": "Applicative apply for maybes: combine a maybe function and a maybe argument.",

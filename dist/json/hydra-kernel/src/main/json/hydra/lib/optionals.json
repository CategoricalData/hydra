    {
      "primitive": {
        "name": "hydra.lib.optionals.cases",
        "metadata": {
          "description": "Case analysis on an optional, with cases-style argument order.",
          "comments": [
            "cases(m, def, f) returns f(x) when m is given(x), and def when m is none.",
            "The fundamental eliminator for the optional type; every other primitive in this namespace can be derived from it. The optional value is the first argument, matching the convention for case-statement-like elimination.",
            "Total. Argument order is (m, def, f) rather than Haskell's maybe :: (def, f, m)."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": []}, {"name": "y", "constraints": []}],
          "parameters": [
            {"name": "arg0", "type": {"optional": {"variable": "x"}}, "isLazy": false},
            {"name": "arg1", "type": {"variable": "y"}, "isLazy": true},
            {"name": "arg2", "type": {"function": {"domain": {"variable": "x"}, "codomain": {"variable": "y"}}}, "isLazy": false}],
          "result": {"type": {"variable": "y"}}},
        "isPure": true,
        "isTotal": true}},

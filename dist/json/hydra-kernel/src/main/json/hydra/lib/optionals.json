      "primitive": {
        "name": "hydra.lib.optionals.apply",
        "metadata": {
          "description": "Applicative apply for optionals: combine an optional function and an optional argument.",
          "comments": [
            "apply(mf, mx) returns given(f x) when mf is given(f) and mx is given(x), and none if either is none.",
            "The applicative apply for optionals; threads a function-in-context with a value-in-context.",
            "Total. Corresponds to Haskell's (<*>) :: Maybe (a -> b) -> Maybe a -> Maybe b."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [{"name": "x", "constraints": []}, {"name": "y", "constraints": []}],
          "parameters": [
            {
              "name": "arg0",
              "type": {"optional": {"function": {"domain": {"variable": "x"}, "codomain": {"variable": "y"}}}},
              "isLazy": false},
            {"name": "arg1", "type": {"optional": {"variable": "x"}}, "isLazy": false}],
          "result": {"type": {"optional": {"variable": "y"}}}},
        "isPure": true,
        "isTotal": true,
        "defaultImplementation": {
          "annotated": {
            "body": {
              "lambda": {
                "parameter": "mf",
                "body": {
                  "lambda": {
                    "parameter": "mx",
                    "body": {
                      "application": {
                        "function": {"application": {"function": {"variable": "hydra.lib.optionals.bind"}, "argument": {"variable": "mf"}}},
                        "argument": {
                          "lambda": {
                            "parameter": "f",
                            "body": {
                              "application": {
                                "function": {
                                  "application": {
                                    "function": {"variable": "hydra.lib.optionals.map"},
                                    "argument": {"lambda": {"parameter": "x", "body": {"application": {"function": {"variable": "f"}, "argument": {"variable": "x"}}}}}}},
                                "argument": {"variable": "mx"}}}}}}}}}}},
            "annotation": {
              "map": [
                {
                  "key": {"variable": "description"},
                  "value": {"literal": {"string": "Applicative apply for optionals, defined in terms of bind and map."}}}]}}}}},

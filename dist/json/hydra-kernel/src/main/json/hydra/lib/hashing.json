  "definitions": [
    {
      "primitive": {
        "name": "hydra.lib.hashing.sha256",
        "metadata": {
          "description": "Compute the SHA-256 digest of a sequence of bytes.",
          "comments": [
            "sha256(bytes) returns the 32-byte SHA-256 digest of bytes. Total: hashing is pure and never fails.",
            "Pairs with hydra.lib.files.readFile, which returns raw bytes, to hash file contents."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [],
          "parameters": [{"name": "arg0", "type": {"literal": "binary"}, "isLazy": false}],
          "result": {"type": {"literal": "binary"}}},
        "isPure": true,
        "isTotal": true}},
    {
      "primitive": {
        "name": "hydra.lib.hashing.sha256Hex",
        "metadata": {
          "description": "Compute the SHA-256 digest of a sequence of bytes as a lowercase hex string.",
          "comments": [
            "sha256Hex(bytes) returns the SHA-256 digest of bytes as a 64-character lowercase hexadecimal string. Equivalent to hex-encoding the output of sha256. Total: hashing is pure and never fails.",
            "Pairs with hydra.lib.files.readFile, which returns raw bytes, to hash file contents."],
          "seeAlso": []},
        "signature": {
          "typeParameters": [],
          "parameters": [{"name": "arg0", "type": {"literal": "binary"}, "isLazy": false}],
          "result": {"type": {"literal": "string"}}},
        "isPure": true,
        "isTotal": true}}]}

{
  "name": "hydra.parsing",
  "metadata": {"description": "Parser combinator types for text parsing", "comments": [], "seeAlso": []},
  "dependencies": [{"module": "hydra.core"}],
  "definitions": [
    {
      "type": {
        "name": "hydra.parsing.ParseError",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "record": [
                  {
                    "name": "message",
                    "type": {
                      "annotated": {
                        "body": {"literal": {"string": {}}},
                        "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "An error message"}}}]}}}},
                  {
                    "name": "remainder",
                    "type": {
                      "annotated": {
                        "body": {"literal": {"string": {}}},
                        "annotation": {
                          "map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "The remaining input at the point of failure"}}}]}}}}]},
              "annotation": {
                "map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "An error which occurred while parsing"}}}]}}}}}},
    {
      "type": {
        "name": "hydra.parsing.ParseResult",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "forall": {
                  "parameter": "a",
                  "body": {
                    "union": [
                      {
                        "name": "success",
                        "type": {
                          "annotated": {
                            "body": {"application": {"function": {"variable": "hydra.parsing.ParseSuccess"}, "argument": {"variable": "a"}}},
                            "annotation": {
                              "map": [
                                {
                                  "key": {"variable": "description"},
                                  "value": {"literal": {"string": "A successful parse, with a value and the remaining unparsed input"}}}]}}}},
                      {
                        "name": "failure",
                        "type": {
                          "annotated": {
                            "body": {"variable": "hydra.parsing.ParseError"},
                            "annotation": {
                              "map": [
                                {
                                  "key": {"variable": "description"},
                                  "value": {"literal": {"string": "A failed parse, with an error message and the remaining input"}}}]}}}}]}}},
              "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "The result of a parse operation"}}}]}}}}}},
    {
      "type": {
        "name": "hydra.parsing.ParseSuccess",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "forall": {
                  "parameter": "a",
                  "body": {
                    "record": [
                      {
                        "name": "value",
                        "type": {
                          "annotated": {
                            "body": {"variable": "a"},
                            "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "The parsed value"}}}]}}}},
                      {
                        "name": "remainder",
                        "type": {
                          "annotated": {
                            "body": {"literal": {"string": {}}},
                            "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "The remaining unparsed input"}}}]}}}}]}}},
              "annotation": {"map": [{"key": {"variable": "description"}, "value": {"literal": {"string": "A successful parse result"}}}]}}}}}},
    {
      "type": {
        "name": "hydra.parsing.Parser",
        "body": {
          "variables": [],
          "body": {
            "annotated": {
              "body": {
                "forall": {
                  "parameter": "a",
                  "body": {
                    "wrap": {
                      "function": {
                        "domain": {"literal": {"string": {}}},
                        "codomain": {"application": {"function": {"variable": "hydra.parsing.ParseResult"}, "argument": {"variable": "a"}}}}}}}},
              "annotation": {
                "map": [
                  {
                    "key": {"variable": "description"},
                    "value": {"literal": {"string": "A parser which consumes characters from a string and produces a value"}}}]}}}}}}]}

(defvar hydra_encode_errors_decoding_error (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.errors.DecodingError" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_errors_empty_list_error (lambda (_) (list :unit nil)))

(defvar hydra_encode_errors_multiple_bindings_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.MultipleBindingsError" (list (make-hydra_core_field "name" (hydra_encode_core_name (funcall (lambda (v) (hydra_errors_multiple_bindings_error-name v)) x))))))))

(defvar hydra_encode_errors_multiple_fields_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.MultipleFieldsError" (list (make-hydra_core_field "fieldName" (hydra_encode_core_name (funcall (lambda (v) (hydra_errors_multiple_fields_error-field_name v)) x))))))))

(defvar hydra_encode_errors_no_matching_field_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.NoMatchingFieldError" (list (make-hydra_core_field "fieldName" (hydra_encode_core_name (funcall (lambda (v) (hydra_errors_no_matching_field_error-field_name v)) x))))))))

(defvar hydra_encode_errors_no_such_binding_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.NoSuchBindingError" (list (make-hydra_core_field "name" (hydra_encode_core_name (funcall (lambda (v) (hydra_errors_no_such_binding_error-name v)) x))))))))

(defvar hydra_encode_errors_not_enough_cases_error (lambda (_) (list :unit nil)))

(defvar hydra_encode_errors_unexpected_shape_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.UnexpectedShapeError" (list (make-hydra_core_field "expected" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) (hydra_errors_unexpected_shape_error-expected v)) x))) (make-hydra_core_field "actual" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) (hydra_errors_unexpected_shape_error-actual v)) x))))))))

(defvar hydra_encode_errors_extraction_error (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :empty_list) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "emptyList" (hydra_encode_errors_empty_list_error y))))) match_value)) ((equal (car match_target) :multiple_bindings) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "multipleBindings" (hydra_encode_errors_multiple_bindings_error y))))) match_value)) ((equal (car match_target) :multiple_fields) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "multipleFields" (hydra_encode_errors_multiple_fields_error y))))) match_value)) ((equal (car match_target) :no_matching_field) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "noMatchingField" (hydra_encode_errors_no_matching_field_error y))))) match_value)) ((equal (car match_target) :no_such_binding) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "noSuchBinding" (hydra_encode_errors_no_such_binding_error y))))) match_value)) ((equal (car match_target) :not_enough_cases) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "notEnoughCases" (hydra_encode_errors_not_enough_cases_error y))))) match_value)) ((equal (car match_target) :unexpected_shape) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ExtractionError" (make-hydra_core_field "unexpectedShape" (hydra_encode_errors_unexpected_shape_error y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_errors_other_inference_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.OtherInferenceError" (list (make-hydra_core_field "path" (hydra_encode_paths_subterm_path (funcall (lambda (v) (hydra_errors_other_inference_error-path v)) x))) (make-hydra_core_field "message" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) (hydra_errors_other_inference_error-message v)) x))))))))

(defvar hydra_encode_errors_unification_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.UnificationError" (list (make-hydra_core_field "leftType" (hydra_encode_core_type (funcall (lambda (v) (hydra_errors_unification_error-left_type v)) x))) (make-hydra_core_field "rightType" (hydra_encode_core_type (funcall (lambda (v) (hydra_errors_unification_error-right_type v)) x))) (make-hydra_core_field "message" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) (hydra_errors_unification_error-message v)) x))))))))

(defvar hydra_encode_errors_unification_inference_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.UnificationInferenceError" (list (make-hydra_core_field "path" (hydra_encode_paths_subterm_path (funcall (lambda (v) (hydra_errors_unification_inference_error-path v)) x))) (make-hydra_core_field "cause" (hydra_encode_errors_unification_error (funcall (lambda (v) (hydra_errors_unification_inference_error-cause v)) x))))))))

(defvar hydra_encode_errors_inference_error (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :checking) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.InferenceError" (make-hydra_core_field "checking" (hydra_encode_error_checking_checking_error y))))) match_value)) ((equal (car match_target) :other) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.InferenceError" (make-hydra_core_field "other" (hydra_encode_errors_other_inference_error y))))) match_value)) ((equal (car match_target) :unification) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.InferenceError" (make-hydra_core_field "unification" (hydra_encode_errors_unification_inference_error y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_errors_other_error (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.errors.OtherError" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_errors_no_such_primitive_error (lambda (x) (list :record (make-hydra_core_record "hydra.errors.NoSuchPrimitiveError" (list (make-hydra_core_field "name" (hydra_encode_core_name (funcall (lambda (v) (hydra_errors_no_such_primitive_error-name v)) x))))))))

(defvar hydra_encode_errors_other_resolution_error (lambda (x) (list :wrap (make-hydra_core_wrapped_term "hydra.errors.OtherResolutionError" (funcall (lambda (x2) (list :literal (list :string x2))) (funcall (lambda (v) v) x))))))

(defvar hydra_encode_errors_resolution_error (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :no_such_binding) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ResolutionError" (make-hydra_core_field "noSuchBinding" (hydra_encode_errors_no_such_binding_error y))))) match_value)) ((equal (car match_target) :no_such_primitive) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ResolutionError" (make-hydra_core_field "noSuchPrimitive" (hydra_encode_errors_no_such_primitive_error y))))) match_value)) ((equal (car match_target) :no_matching_field) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ResolutionError" (make-hydra_core_field "noMatchingField" (hydra_encode_errors_no_matching_field_error y))))) match_value)) ((equal (car match_target) :other) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ResolutionError" (make-hydra_core_field "other" (hydra_encode_errors_other_resolution_error y))))) match_value)) ((equal (car match_target) :unexpected_shape) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.ResolutionError" (make-hydra_core_field "unexpectedShape" (hydra_encode_errors_unexpected_shape_error y))))) match_value)))) (cadr match_target))))

(defvar hydra_encode_errors_error (lambda (match_target) (funcall (lambda (match_value) (cond ((equal (car match_target) :checking) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "checking" (hydra_encode_error_checking_checking_error y))))) match_value)) ((equal (car match_target) :decoding) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "decoding" (hydra_encode_errors_decoding_error y))))) match_value)) ((equal (car match_target) :duplicate_binding) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "duplicateBinding" (hydra_encode_error_core_duplicate_binding_error y))))) match_value)) ((equal (car match_target) :duplicate_field) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "duplicateField" (hydra_encode_error_core_duplicate_field_error y))))) match_value)) ((equal (car match_target) :extraction) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "extraction" (hydra_encode_errors_extraction_error y))))) match_value)) ((equal (car match_target) :inference) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "inference" (hydra_encode_errors_inference_error y))))) match_value)) ((equal (car match_target) :other) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "other" (hydra_encode_errors_other_error y))))) match_value)) ((equal (car match_target) :resolution) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "resolution" (hydra_encode_errors_resolution_error y))))) match_value)) ((equal (car match_target) :undefined_field) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "undefinedField" (hydra_encode_error_core_undefined_field_error y))))) match_value)) ((equal (car match_target) :undefined_term_variable) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "undefinedTermVariable" (hydra_encode_error_core_undefined_term_variable_error y))))) match_value)) ((equal (car match_target) :untyped_term_variable) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "untypedTermVariable" (hydra_encode_error_core_untyped_term_variable_error y))))) match_value)) ((equal (car match_target) :unexpected_term_variant) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "unexpectedTermVariant" (hydra_encode_error_core_unexpected_term_variant_error y))))) match_value)) ((equal (car match_target) :unexpected_type_variant) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "unexpectedTypeVariant" (hydra_encode_error_core_unexpected_type_variant_error y))))) match_value)) ((equal (car match_target) :unification) (funcall (lambda (y) (list :inject (make-hydra_core_injection "hydra.errors.Error" (make-hydra_core_field "unification" (hydra_encode_errors_unification_error y))))) match_value)))) (cadr match_target))))

(provide 'hydra.encode.errors)

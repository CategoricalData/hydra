(define results (run-test-group "" hydra_test_test_suite_all_tests))

(newline)
(display "========================================\n")
(display (string-append "Pass: " (number->string (car results)) "\n"))
(display (string-append "Fail: " (number->string (cadr results)) "\n"))
(display (string-append "Skip: " (number->string (caddr results)) "\n"))

(if (> (cadr results) 0)

(define-library (hydra encode grammar)
(export hydra_encode_grammar_constant hydra_encode_grammar_label hydra_encode_grammar_regex hydra_encode_grammar_symbol hydra_encode_grammar_labeled_pattern hydra_encode_grammar_pattern hydra_encode_grammar_production hydra_encode_grammar_grammar)
(import (scheme base) (hydra core) (hydra grammar) (hydra lib lists))
(begin
(define hydra_encode_grammar_constant (lambda (x) (list 'wrap (make-hydra_core_wrapped_term "hydra.grammar.Constant" ((lambda (x) (list 'literal (list 'string x))) ((lambda (v) v) x))))))
(define hydra_encode_grammar_label (lambda (x) (list 'wrap (make-hydra_core_wrapped_term "hydra.grammar.Label" ((lambda (x) (list 'literal (list 'string x))) ((lambda (v) v) x))))))
(define hydra_encode_grammar_regex (lambda (x) (list 'wrap (make-hydra_core_wrapped_term "hydra.grammar.Regex" ((lambda (x) (list 'literal (list 'string x))) ((lambda (v) v) x))))))
(define hydra_encode_grammar_symbol (lambda (x) (list 'wrap (make-hydra_core_wrapped_term "hydra.grammar.Symbol" ((lambda (x) (list 'literal (list 'string x))) ((lambda (v) v) x))))))
(define hydra_encode_grammar_labeled_pattern (lambda (x) (list 'record (make-hydra_core_record "hydra.grammar.LabeledPattern" (list (make-hydra_core_field "label" (hydra_encode_grammar_label ((lambda (v) (hydra_grammar_labeled_pattern-label v)) x))) (make-hydra_core_field "pattern" (hydra_encode_grammar_pattern ((lambda (v) (hydra_grammar_labeled_pattern-pattern v)) x))))))))
(define hydra_encode_grammar_pattern (lambda (match_target) ((lambda (match_value) (cond ((equal? (car match_target) 'alternatives) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "alternatives" ((lambda (xs) (list 'list ((hydra_lib_lists_map hydra_encode_grammar_pattern) xs))) y))))) match_value)) ((equal? (car match_target) 'constant) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "constant" (hydra_encode_grammar_constant y))))) match_value)) ((equal? (car match_target) 'ignored) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "ignored" (hydra_encode_grammar_pattern y))))) match_value)) ((equal? (car match_target) 'labeled) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "labeled" (hydra_encode_grammar_labeled_pattern y))))) match_value)) ((equal? (car match_target) 'nil) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "nil" ((lambda (_) (list 'unit '())) y))))) match_value)) ((equal? (car match_target) 'nonterminal) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "nonterminal" (hydra_encode_grammar_symbol y))))) match_value)) ((equal? (car match_target) 'option) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "option" (hydra_encode_grammar_pattern y))))) match_value)) ((equal? (car match_target) 'plus) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "plus" (hydra_encode_grammar_pattern y))))) match_value)) ((equal? (car match_target) 'regex) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "regex" (hydra_encode_grammar_regex y))))) match_value)) ((equal? (car match_target) 'sequence) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "sequence" ((lambda (xs) (list 'list ((hydra_lib_lists_map hydra_encode_grammar_pattern) xs))) y))))) match_value)) ((equal? (car match_target) 'star) ((lambda (y) (list 'union (make-hydra_core_injection "hydra.grammar.Pattern" (make-hydra_core_field "star" (hydra_encode_grammar_pattern y))))) match_value)))) (cadr match_target))))
(define hydra_encode_grammar_production (lambda (x) (list 'record (make-hydra_core_record "hydra.grammar.Production" (list (make-hydra_core_field "symbol" (hydra_encode_grammar_symbol ((lambda (v) (hydra_grammar_production-symbol v)) x))) (make-hydra_core_field "pattern" (hydra_encode_grammar_pattern ((lambda (v) (hydra_grammar_production-pattern v)) x))))))))
(define hydra_encode_grammar_grammar (lambda (x) (list 'wrap (make-hydra_core_wrapped_term "hydra.grammar.Grammar" ((lambda (xs) (list 'list ((hydra_lib_lists_map hydra_encode_grammar_production) xs))) ((lambda (v) v) x))))))))

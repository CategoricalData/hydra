{
  "definitions": [
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Asset",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "An Asset is an object that contains a URI to data associated with the Item that can be downloaded or streamed. It is allowed to add additional fields."}}}],
              "body": {
                "record": [
                  {
                    "name": "href",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "URI to the asset object. Relative and absolute URI are both allowed."}}}],
                        "body": {"variable": "hydra.ext.org.stacspec.items.Uri"}}}},
                  {
                    "name": "title",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The displayed title for clients and users."}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "description",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A description of the Asset providing additional details, such as how it was processed or created. CommonMark 0.29 syntax MAY be used for rich text representation."}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}},
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "Media type of the asset. See the common media types in the best practice doc for commonly used asset types."}}}],
                        "body": {"maybe": {"variable": "hydra.ext.org.stacspec.items.MediaType"}}}}},
                  {
                    "name": "roles",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The semantic roles of the asset, similar to the use of rel in links."}}}],
                        "body": {"list": {"variable": "hydra.ext.org.stacspec.items.Role"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Item",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "This object describes a STAC Item. The fields id, type, bbox, geometry and properties are inherited from GeoJSON."}}}],
              "body": {
                "record": [
                  {
                    "name": "feature",
                    "type": {"variable": "hydra.ext.org.geojson.model.Feature"}},
                  {
                    "name": "stacVersion",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The STAC version the Item implements"}}}],
                        "body": {"variable": "hydra.ext.org.stacspec.items.StacVersion"}}}},
                  {
                    "name": "stacExtensions",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "A list of extensions the Item implements"}}}],
                        "body": {"list": {"variable": "hydra.ext.org.stacspec.items.Url"}}}}},
                  {
                    "name": "links",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "List of link objects to resources and related URLs. A link with the rel set to self is strongly recommended."}}}],
                        "body": {"list": {"variable": "hydra.ext.org.stacspec.items.Link"}}}}},
                  {
                    "name": "assets",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "Dictionary of asset objects that can be downloaded, each with a unique key."}}}],
                        "body": {
                          "map": {
                            "keys": {"literal": {"string": {}}},
                            "values": {"variable": "hydra.ext.org.stacspec.items.Asset"}}}}}},
                  {
                    "name": "collection",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The id of the STAC Collection this Item references to (see collection relation type). This field is required if such a relation type is present and is not allowed otherwise. This field provides an easy way for a user to search for any Items that belong in a specified Collection. Must be a non-empty string."}}}],
                        "body": {"maybe": {"variable": "hydra.ext.org.geojson.model.Id"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Link",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "This object describes a relationship with another entity. Data providers are advised to be liberal with the links section, to describe things like the Catalog an Item is in, related Items, parent or child Items (modeled in different ways, like an 'acquisition' or derived data). It is allowed to add additional fields such as a title and type."}}}],
              "body": {
                "record": [
                  {
                    "name": "href",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The actual link in the format of an URL. Relative and absolute links are both allowed."}}}],
                        "body": {"variable": "hydra.ext.org.stacspec.items.Url"}}}},
                  {
                    "name": "rel",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "Relationship between the current document and the linked document. See chapter \"Relation types\" for more information."}}}],
                        "body": {"variable": "hydra.ext.org.stacspec.items.RelationType"}}}},
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "Media type of the referenced entity."}}}],
                        "body": {"maybe": {"variable": "hydra.ext.org.stacspec.items.MediaType"}}}}},
                  {
                    "name": "title",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A human readable title to be used in rendered displays of the link."}}}],
                        "body": {"maybe": {"literal": {"string": {}}}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.MediaType",
        "type": {
          "constraints": null,
          "type": {"wrap": {"literal": {"string": {}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.RelationType",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "STAC Items use a variety of rel types in the link object, to describe the exact nature of the link between this Item and the entity it is linking to. It is recommended to use the official IANA Link Relation Types where possible. The following table explains places where STAC use custom rel types are used with Items. This happens where there is not a clear official option, or where STAC uses an official type but adds additional meaning for the STAC context."}}}],
              "body": {
                "union": [
                  {
                    "name": "iana",
                    "type": {"variable": "hydra.ext.org.iana.linkrelations.LinkRelationType"}},
                  {
                    "name": "stac",
                    "type": {"variable": "hydra.ext.org.stacspec.items.StacRelationType"}},
                  {"name": "other", "type": {"literal": {"string": {}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Role",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "The roles field is used to describe the purpose of each asset. It is recommended to include one for every asset, to give users a sense of why they might want to make use of the asset. There are some emerging standards that enable clients to take particular action when they encounter particular roles, listed below. But implementors are encouraged to come up with their own terms to describe the role."}}}],
              "body": {
                "union": [
                  {
                    "name": "thumbnail",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "An asset that represents a thumbnail of the Item, typically a true color image (for Items with assets in the visible wavelengths), lower-resolution (typically smaller 600x600 pixels), and typically a JPEG or PNG (suitable for display in a web browser). Multiple assets may have this purpose, but it recommended that the type and roles be unique tuples. For example, Sentinel-2 L2A provides thumbnail images in both JPEG and JPEG2000 formats, and would be distinguished by their media types."}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "overview",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "An asset that represents a possibly larger view than the thumbnail of the Item, for example, a true color composite of multi-band data."}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "data",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The data itself. This is a suggestion for a common role for data files to be used in case data providers don't come up with their own names and semantics."}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "metadata",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A metadata sidecar file describing the data in this Item, for example the Landsat-8 MTL file."}}}],
                        "body": {"unit": {}}}}},
                  {"name": "other", "type": {"literal": {"string": {}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.StacRelationType",
        "type": {
          "constraints": null,
          "type": {
            "union": [
              {
                "name": "self",
                "type": {
                  "annotated": {
                    "annotation": [
                      {
                        "@key": "description",
                        "@value": {
                          "literal": {
                            "string": "STRONGLY RECOMMENDED. Absolute URL to the Item if it is available at a public URL. This is particularly useful when in a download package that includes metadata, so that the downstream user can know where the data has come from."}}}],
                    "body": {"unit": {}}}}},
              {
                "name": "root",
                "type": {
                  "annotated": {
                    "annotation": [
                      {
                        "@key": "description",
                        "@value": {
                          "literal": {"string": "URL to the root STAC entity (Catalog or Collection)."}}}],
                    "body": {"unit": {}}}}},
              {
                "name": "parent",
                "type": {
                  "annotated": {
                    "annotation": [
                      {
                        "@key": "description",
                        "@value": {
                          "literal": {"string": "URL to the parent STAC entity (Catalog or Collection)."}}}],
                    "body": {"unit": {}}}}},
              {
                "name": "collection",
                "type": {
                  "annotated": {
                    "annotation": [
                      {
                        "@key": "description",
                        "@value": {
                          "literal": {
                            "string": "STRONGLY RECOMMENDED. URL to a Collection. Absolute URLs should be used whenever possible. The referenced Collection is STRONGLY RECOMMENDED to implement the same STAC version as the Item. A link with this rel type is required if the collection field in properties is present."}}}],
                    "body": {"unit": {}}}}},
              {
                "name": "derivedFrom",
                "type": {
                  "annotated": {
                    "annotation": [
                      {
                        "@key": "description",
                        "@value": {
                          "literal": {
                            "string": "URL to a STAC Item that was used as input data in the creation of this Item."}}}],
                    "body": {"unit": {}}}}}]},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.StacVersion",
        "type": {
          "constraints": null,
          "type": {"wrap": {"literal": {"string": {}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Uri",
        "type": {
          "constraints": null,
          "type": {"wrap": {"literal": {"string": {}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.ext.org.stacspec.items.Url",
        "type": {
          "constraints": null,
          "type": {"wrap": {"literal": {"string": {}}}},
          "variables": []}}}],
  "description": [
    "A model for SpatioTemporal Asset Catalog (STAC) Items. See https://github.com/radiantearth/stac-spec/blob/master/item-spec/item-spec.md"],
  "namespace": "hydra.ext.org.stacspec.items",
  "termDependencies": ["hydra.ext.org.geojson.model", "hydra.ext.org.iana.linkrelations"],
  "typeDependencies": ["hydra.core"]}

{
  "definitions": [
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.BoundingBox",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A GeoJSON object MAY have a member named \"bbox\" to include information on the coordinate range for its Geometries, Features, or FeatureCollections.  The value of the bbox member MUST be an array of length 2*n where n is the number of dimensions represented in the contained geometries, with all axes of the most southwesterly point followed by all axes of the more northeasterly point.  The axes order of a bbox follows the axes order of geometries."}}}],
            "body": {
              "wrap": {"list": {"variable": "hydra.ext.org.geojson.model.CoordinateRange"}}}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.CoordinateRange",
        "type": {
          "record": [
            {"name": "min", "type": {"literal": {"float": {"bigfloat": {}}}}},
            {"name": "max", "type": {"literal": {"float": {"bigfloat": {}}}}}]}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Feature",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A Feature object represents a spatially bounded thing.  Every Feature object is a GeoJSON object no matter where it occurs in a GeoJSON text."}}}],
            "body": {
              "record": [
                {
                  "name": "geometry",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "A Feature object has a member with the name \"geometry\".  The value of the geometry member SHALL be either a Geometry object as defined above or, in the case that the Feature is unlocated, a JSON null value."}}}],
                      "body": {"maybe": {"variable": "hydra.ext.org.geojson.model.Geometry"}}}}},
                {
                  "name": "properties",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "A Feature object has a member with the name \"properties\".  The value of the properties member is an object (any JSON object or a JSON null value)."}}}],
                      "body": {
                        "maybe": {
                          "map": {
                            "keys": {"literal": {"string": {}}},
                            "values": {"variable": "hydra.json.model.Value"}}}}}}},
                {
                  "name": "id",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "If a Feature has a commonly used identifier, that identifier SHOULD be included as a member of the Feature object with the name \"id\", and the value of this member is either a JSON string or number."}}}],
                      "body": {"maybe": {"variable": "hydra.ext.org.geojson.model.Id"}}}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.FeatureCollection",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A GeoJSON object with the type \"FeatureCollection\" is a FeatureCollection object.  A FeatureCollection object has a member with the name \"features\".  The value of \"features\" is a JSON array. Each element of the array is a Feature object as defined above.  It is possible for this array to be empty."}}}],
            "body": {
              "record": [
                {
                  "name": "features",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Feature"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.GeometryCollection",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A GeoJSON object with type \"GeometryCollection\" is a Geometry object. A GeometryCollection has a member with the name \"geometries\".  The value of \"geometries\" is an array.  Each element of this array is a GeoJSON Geometry object.  It is possible for this array to be empty."}}}],
            "body": {
              "record": [
                {
                  "name": "geometries",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Geometry"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Geometry",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A Geometry object represents points, curves, and surfaces in coordinate space.  Every Geometry object is a GeoJSON object no matter where it occurs in a GeoJSON text."}}}],
            "body": {
              "union": [
                {
                  "name": "point",
                  "type": {"variable": "hydra.ext.org.geojson.model.Point"}},
                {
                  "name": "multiPoint",
                  "type": {"variable": "hydra.ext.org.geojson.model.MultiPoint"}},
                {
                  "name": "lineString",
                  "type": {"variable": "hydra.ext.org.geojson.model.LineString"}},
                {
                  "name": "multiLineString",
                  "type": {"variable": "hydra.ext.org.geojson.model.MultiLineString"}},
                {
                  "name": "polygon",
                  "type": {"variable": "hydra.ext.org.geojson.model.Polygon"}},
                {
                  "name": "multiPolygon",
                  "type": {"variable": "hydra.ext.org.geojson.model.MultiPolygon"}},
                {
                  "name": "geometryCollection",
                  "type": {"variable": "hydra.ext.org.geojson.model.GeometryCollection"}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Id",
        "type": {
          "union": [
            {"name": "number", "type": {"literal": {"float": {"bigfloat": {}}}}},
            {"name": "string", "type": {"literal": {"string": {}}}}]}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.LineString",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"LineString\", the \"coordinates\" member is an array of two or more positions."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Position"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.MultiLineString",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"MultiLineString\", the \"coordinates\" member is an array of LineString coordinate arrays."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.LineString"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.MultiPoint",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"MultiPoint\", the \"coordinates\" member is an array of positions."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Point"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.MultiPolygon",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"MultiPolygon\", the \"coordinates\" member is an array of Polygon coordinate arrays."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Polygon"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Object",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A GeoJSON object represents a Geometry, Feature, or collection of Features."}}}],
            "body": {
              "union": [
                {
                  "name": "geometry",
                  "type": {"variable": "hydra.ext.org.geojson.model.Geometry"}},
                {
                  "name": "feature",
                  "type": {"variable": "hydra.ext.org.geojson.model.Feature"}},
                {
                  "name": "featureCollection",
                  "type": {"variable": "hydra.ext.org.geojson.model.FeatureCollection"}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Point",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"Point\", the \"coordinates\" member is a single position."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"variable": "hydra.ext.org.geojson.model.Position"}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Polygon",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "For type \"Polygon\", the \"coordinates\" member MUST be an array of linear ring coordinate arrays.\nFor Polygons with more than one of these rings, the first MUST be the exterior ring, and any others MUST be interior rings.  The exterior ring bounds the surface, and the interior rings (if present) bound holes within the surface."}}}],
            "body": {
              "record": [
                {
                  "name": "coordinates",
                  "type": {"list": {"variable": "hydra.ext.org.geojson.model.Position"}}},
                {
                  "name": "bbox",
                  "type": {"maybe": {"variable": "hydra.ext.org.geojson.model.BoundingBox"}}}]}}}}},
    {
      "type": {
        "name": "hydra.ext.org.geojson.model.Position",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A position is an array of numbers.  There MUST be two or more elements.  The first two elements are longitude and latitude, or easting and northing, precisely in that order and using decimal numbers.  Altitude or elevation MAY be included as an optional third element."}}}],
            "body": {
              "record": [
                {"name": "latitude", "type": {"literal": {"float": {"bigfloat": {}}}}},
                {
                  "name": "longitude",
                  "type": {"literal": {"float": {"bigfloat": {}}}}},
                {
                  "name": "altitude",
                  "type": {"maybe": {"literal": {"float": {"bigfloat": {}}}}}}]}}}}}],
  "description": [
    "A GeoJSON model based on the specification at https://www.rfc-editor.org/rfc/rfc7946. This model provides some additional structure beyond the JSON encoding described in the specification; For example, it provides MultiPoint not as an object with an array of coordinates which encode points, but as an array of Points. A BoundingBox is not simply an list of numbers, but a list of CoordinateRanges."],
  "namespace": "hydra.ext.org.geojson.model",
  "termDependencies": ["hydra.json.model"],
  "typeDependencies": []}

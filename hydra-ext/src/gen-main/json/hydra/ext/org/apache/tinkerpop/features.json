                      "body": {"literal": {"boolean": {}}}}}},
                {
                  "name": "supportsPersistence",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "Determines if the Graph implementation supports persisting it's contents natively to disk."}}}],
                      "body": {"literal": {"boolean": {}}}}}},
                {
                  "name": "supportsThreadedTransactions",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "Determines if the Graph implementation supports threaded transactions which allow a transaction to be executed across multiple threads via Transaction.createThreadedTx()."}}}],
                      "body": {"literal": {"boolean": {}}}}}},
                {
                  "name": "supportsTransactions",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "Determines if the Graph implementations supports transactions."}}}],
                      "body": {"literal": {"boolean": {}}}}}},

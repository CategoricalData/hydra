                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "Determines if the Graph implementations supports read operations as executed with the GraphTraversalSource.io(String) step."}}}],
                      "body": {"literal": {"boolean": {}}}}}},
                {
                  "name": "supportsIoWrite",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {

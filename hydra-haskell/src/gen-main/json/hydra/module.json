                      "body": {"list": {"variable": "hydra.module.Namespace"}}}}},
                {
                  "name": "description",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {"string": "An optional human-readable description of the module"}}}],
                      "body": {"maybe": {"literal": {"string": {}}}}}}}]}}}}},
    {
      "type": {
        "name": "hydra.module.Namespace",

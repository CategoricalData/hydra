    {
      "type": {
        "name": "hydra.module.Module",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A logical collection of elements in the same namespace, having dependencies on zero or more other modules"}}}],
            "body": {
              "record": [
                {
                  "name": "namespace",
                  "type": {
                    "annotated": {
                      "annotation": [

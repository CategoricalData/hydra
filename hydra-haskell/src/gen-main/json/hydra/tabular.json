                  "@value": {
                    "literal": {"string": "A column type, consisting of a name and a value type"}}}],
              "body": {
                "record": [
                  {"name": "name", "type": {"variable": "hydra.relational.ColumnName"}},
                  {"name": "type", "type": {"variable": "hydra.core.Type"}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.tabular.DataRow",
        "type": {
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A data row, containing optional-valued cells; one per column"}}}],
              "body": {
                "forall": {
                  "body": {"wrap": {"list": {"maybe": {"variable": "v"}}}},
                  "parameter": "v"}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.tabular.HeaderRow",
        "type": {
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A header row, containing column names (but no types or data)"}}}],
              "body": {"wrap": {"list": {"literal": {"string": {}}}}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.tabular.Table",
        "type": {
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A simple table as in a CSV file, having an optional header row and any number of data rows"}}}],
              "body": {
                "forall": {
                  "body": {
                    "record": [
                      {
                        "name": "header",

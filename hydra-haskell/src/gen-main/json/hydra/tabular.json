                            "annotation": [
                              {
                                "@key": "description",
                                "@value": {
                                  "literal": {
                                    "string": "The optional header row of the table. If present, the header must have the same number of cells as each data row."}}}],
                            "body": {"maybe": {"variable": "hydra.tabular.HeaderRow"}}}}},
                      {
                        "name": "data",
                        "type": {
                          "annotated": {
                            "annotation": [
                              {
                                "@key": "description",
                                "@value": {
                                  "literal": {
                                    "string": "The data rows of the table. Each row must have the same number of cells."}}}],
                            "body": {
                              "list": {
                                "application": {
                                  "argument": {"variable": "v"},
                                  "function": {"variable": "hydra.tabular.DataRow"}}}}}}}]},
                  "parameter": "v"}}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.tabular.TableType",
        "type": {
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",

                  {
                    "name": "notAForallType",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "A type that is not a forall type when one was expected"}}}],
                        "body": {"variable": "hydra.error.checking.NotAForallTypeError"}}}},
                  {
                    "name": "notAFunctionType",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",

                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A description of the context in which the types were expected to be equal"}}}],
                        "body": {"literal": {"string": {}}}}}}]}}},
          "variables": []}}},
    {

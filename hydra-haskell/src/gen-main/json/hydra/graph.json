{
  "definitions": [
    {
      "type": {
        "name": "hydra.graph.Graph",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A graph, or lexical environment which binds names to terms, types, primitives, and metadata"}}}],
              "body": {
                "record": [
                  {
                    "name": "boundTerms",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The terms bound by all term variables in scope"}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.core.Term"}}}}}},
                  {
                    "name": "boundTypes",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The type schemes of all term variables in scope"}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.core.TypeScheme"}}}}}},
                  {
                    "name": "classConstraints",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A mutable map from type variable names to their accumulated class constraints. This is populated during type inference when operations requiring Eq or Ord are encountered."}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.core.TypeVariableMetadata"}}}}}},
                  {
                    "name": "lambdaVariables",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The set of term variables introduced by specifically by lambdas"}}}],
                        "body": {"set": {"variable": "hydra.core.Name"}}}}},
                  {
                    "name": "metadata",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "Any additional metadata bound to term variables in scope"}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.core.Term"}}}}}},
                  {
                    "name": "primitives",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "All primitive functions and constants by name"}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.graph.Primitive"}}}}}},
                  {
                    "name": "schemaTypes",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "All schema types (type schemes) in scope"}}}],
                        "body": {
                          "map": {
                            "keys": {"variable": "hydra.core.Name"},
                            "values": {"variable": "hydra.core.TypeScheme"}}}}}},
                  {
                    "name": "typeVariables",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The set of type variables introduced specifically by type lambdas"}}}],
                        "body": {"set": {"variable": "hydra.core.Name"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.graph.Primitive",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A built-in function or constant"}}}],
              "body": {
                "record": [
                  {
                    "name": "name",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The unique name of the primitive function"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The type signature of the primitive function"}}}],
                        "body": {"variable": "hydra.core.TypeScheme"}}}},
                  {
                    "name": "implementation",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A concrete implementation of the primitive function. The Context and Graph parameters are needed by higher-order primitives (e.g. lists.map, lists.foldl, eithers.bind) which must evaluate function arguments via term reduction; the Graph provides variable and primitive bindings, while the Context supports tracing and error reporting."}}}],
                        "body": {
                          "function": {
                            "codomain": {
                              "function": {
                                "codomain": {
                                  "function": {
                                    "codomain": {
                                      "either": {
                                        "left": {
                                          "application": {
                                            "argument": {"variable": "hydra.errors.Error"},
                                            "function": {"variable": "hydra.context.InContext"}}},
                                        "right": {"variable": "hydra.core.Term"}}},
                                    "domain": {"list": {"variable": "hydra.core.Term"}}}},
                                "domain": {"variable": "hydra.graph.Graph"}}},
                            "domain": {"variable": "hydra.context.Context"}}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.graph.TermCoder",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A type together with a coder for mapping terms into arguments for primitive functions, and mapping computed results into terms."}}}],
              "body": {
                "forall": {
                  "body": {
                    "record": [
                      {
                        "name": "type",
                        "type": {
                          "annotated": {
                            "annotation": [
                              {
                                "@key": "description",
                                "@value": {"literal": {"string": "The Hydra type of encoded terms"}}}],
                            "body": {"variable": "hydra.core.Type"}}}},
                      {
                        "name": "encode",
                        "type": {
                          "annotated": {
                            "annotation": [
                              {
                                "@key": "description",
                                "@value": {
                                  "literal": {"string": "An encode function from terms to native values"}}}],
                            "body": {
                              "function": {
                                "codomain": {
                                  "function": {
                                    "codomain": {
                                      "function": {
                                        "codomain": {
                                          "either": {
                                            "left": {
                                              "application": {
                                                "argument": {"variable": "hydra.errors.Error"},
                                                "function": {"variable": "hydra.context.InContext"}}},
                                            "right": {"variable": "a"}}},
                                        "domain": {"variable": "hydra.core.Term"}}},
                                    "domain": {"variable": "hydra.graph.Graph"}}},
                                "domain": {"variable": "hydra.context.Context"}}}}}},
                      {
                        "name": "decode",
                        "type": {
                          "annotated": {
                            "annotation": [
                              {
                                "@key": "description",
                                "@value": {
                                  "literal": {"string": "A decode function from native values to terms"}}}],
                            "body": {
                              "function": {
                                "codomain": {
                                  "function": {
                                    "codomain": {
                                      "either": {
                                        "left": {
                                          "application": {
                                            "argument": {"variable": "hydra.errors.Error"},
                                            "function": {"variable": "hydra.context.InContext"}}},
                                        "right": {"variable": "hydra.core.Term"}}},
                                    "domain": {"variable": "a"}}},
                                "domain": {"variable": "hydra.context.Context"}}}}}}]},
                  "parameter": "a"}}}},
          "variables": []}}}],
  "description": ["The extension to graphs of Hydra's core type system (hydra.core)"],
  "namespace": "hydra.graph",
  "termDependencies": ["hydra.context", "hydra.core", "hydra.errors"],
  "typeDependencies": ["hydra.context", "hydra.core", "hydra.errors"]}

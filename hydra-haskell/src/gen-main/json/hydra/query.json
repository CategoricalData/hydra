{
  "definitions": [
    {
      "type": {
        "name": "hydra.query.ComparisonConstraint",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "One of several comparison operators"}}}],
              "body": {
                "union": [
                  {"name": "equal", "type": {"unit": {}}},
                  {"name": "notEqual", "type": {"unit": {}}},
                  {"name": "lessThan", "type": {"unit": {}}},
                  {"name": "greaterThan", "type": {"unit": {}}},
                  {"name": "lessThanOrEqual", "type": {"unit": {}}},
                  {"name": "greaterThanOrEqual", "type": {"unit": {}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Edge",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "An abstract edge based on a record type"}}}],
              "body": {
                "record": [
                  {
                    "name": "type",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The name of a record type, for which the edge also specifies an out- and an in- projection"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "out",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The field representing the out-projection of the edge. Defaults to 'out'."}}}],
                        "body": {"maybe": {"variable": "hydra.core.Name"}}}}},
                  {
                    "name": "in",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The field representing the in-projection of the edge. Defaults to 'in'."}}}],
                        "body": {"maybe": {"variable": "hydra.core.Name"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.GraphPattern",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A query pattern which matches within a designated component subgraph"}}}],
              "body": {
                "record": [
                  {
                    "name": "graph",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The name of the component graph"}}}],
                        "body": {"variable": "hydra.core.Name"}}}},
                  {
                    "name": "patterns",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The patterns to match within the subgraph"}}}],
                        "body": {"list": {"variable": "hydra.query.Pattern"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Node",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A node in a query expression; it may be a term, a variable, or a wildcard"}}}],
              "body": {
                "union": [
                  {
                    "name": "term",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A graph term; an expression which is valid in the graph being matched"}}}],
                        "body": {"variable": "hydra.core.Term"}}}},
                  {
                    "name": "variable",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A query variable, not to be confused with a variable term"}}}],
                        "body": {"variable": "hydra.query.Variable"}}}},
                  {
                    "name": "wildcard",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "An anonymous variable which we do not care to join across patterns"}}}],
                        "body": {"unit": {}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Path",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A query path"}}}],
              "body": {
                "union": [
                  {
                    "name": "step",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "A path given by a single step"}}}],
                        "body": {"variable": "hydra.query.Step"}}}},
                  {
                    "name": "regex",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "A path given by a regular expression quantifier applied to another path"}}}],
                        "body": {"variable": "hydra.query.RegexSequence"}}}},
                  {
                    "name": "inverse",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "A path given by the inverse of another path"}}}],
                        "body": {"variable": "hydra.query.Path"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.PathEquation",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A declared equivalence between two abstract paths in a graph"}}}],
              "body": {
                "record": [
                  {
                    "name": "left",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The left-hand side of the equation"}}}],
                        "body": {"variable": "hydra.query.Path"}}}},
                  {
                    "name": "right",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The right-hand side of the equation"}}}],
                        "body": {"variable": "hydra.query.Path"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Pattern",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A query pattern"}}}],
              "body": {
                "union": [
                  {
                    "name": "triple",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "A subject/predicate/object pattern"}}}],
                        "body": {"variable": "hydra.query.TriplePattern"}}}},
                  {
                    "name": "negation",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The negation of another pattern"}}}],
                        "body": {"variable": "hydra.query.Pattern"}}}},
                  {
                    "name": "conjunction",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The conjunction ('and') of several other patterns"}}}],
                        "body": {"list": {"variable": "hydra.query.Pattern"}}}}},
                  {
                    "name": "disjunction",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The disjunction (inclusive 'or') of several other patterns"}}}],
                        "body": {"list": {"variable": "hydra.query.Pattern"}}}}},
                  {
                    "name": "graph",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "A pattern which matches within a named subgraph"}}}],
                        "body": {"variable": "hydra.query.GraphPattern"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.PatternImplication",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "A pattern which, if it matches in a given graph, implies that another pattern must also match. Query variables are shared between the two patterns."}}}],
              "body": {
                "record": [
                  {
                    "name": "antecedent",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The pattern which, if it matches, triggers the constraint"}}}],
                        "body": {"variable": "hydra.query.Pattern"}}}},
                  {
                    "name": "consequent",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The pattern which must also match when the antecedent matches"}}}],
                        "body": {"variable": "hydra.query.Pattern"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Query",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A SELECT-style graph pattern matching query"}}}],
              "body": {
                "record": [
                  {
                    "name": "variables",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The variables selected by the query"}}}],
                        "body": {"list": {"variable": "hydra.query.Variable"}}}}},
                  {
                    "name": "patterns",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The patterns to be matched"}}}],
                        "body": {"list": {"variable": "hydra.query.Pattern"}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Range",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A range from min to max, inclusive"}}}],
              "body": {
                "record": [
                  {
                    "name": "min",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The minimum value (inclusive)"}}}],
                        "body": {"literal": {"integer": {"int32": {}}}}}}},
                  {
                    "name": "max",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The maximum value (inclusive)"}}}],
                        "body": {"literal": {"integer": {"int32": {}}}}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.RegexQuantifier",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A regular expression quantifier"}}}],
              "body": {
                "union": [
                  {
                    "name": "one",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "No quantifier; matches a single occurrence"}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "zeroOrOne",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The ? quanifier; matches zero or one occurrence"}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "zeroOrMore",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The * quantifier; matches any number of occurrences"}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "oneOrMore",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The + quantifier; matches one or more occurrences"}}}],
                        "body": {"unit": {}}}}},
                  {
                    "name": "exactly",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The {n} quantifier; matches exactly n occurrences"}}}],
                        "body": {"literal": {"integer": {"int32": {}}}}}}},
                  {
                    "name": "atLeast",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "The {n,} quantifier; matches at least n occurrences"}}}],
                        "body": {"literal": {"integer": {"int32": {}}}}}}},
                  {
                    "name": "range",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {
                                "string": "The {n, m} quantifier; matches between n and m (inclusive) occurrences"}}}],
                        "body": {"variable": "hydra.query.Range"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.RegexSequence",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A path with a regex quantifier"}}}],
              "body": {
                "record": [
                  {
                    "name": "path",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The path to which the quantifier applies"}}}],
                        "body": {"variable": "hydra.query.Path"}}}},
                  {
                    "name": "quantifier",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The quantifier"}}}],
                        "body": {"variable": "hydra.query.RegexQuantifier"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Step",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "An atomic function as part of a query. When applied to a graph, steps are typed by function types."}}}],
              "body": {
                "union": [
                  {
                    "name": "edge",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "An out-to-in traversal of an abstract edge"}}}],
                        "body": {"variable": "hydra.query.Edge"}}}},
                  {
                    "name": "project",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {
                              "literal": {"string": "A projection from a record through one of its fields"}}}],
                        "body": {"variable": "hydra.core.Projection"}}}},
                  {
                    "name": "compare",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "A comparison of two terms"}}}],
                        "body": {"variable": "hydra.query.ComparisonConstraint"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.TriplePattern",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A subject/predicate/object pattern"}}}],
              "body": {
                "record": [
                  {
                    "name": "subject",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The subject of the pattern"}}}],
                        "body": {"variable": "hydra.query.Node"}}}},
                  {
                    "name": "predicate",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The predicate (property) of the pattern"}}}],
                        "body": {"variable": "hydra.query.Path"}}}},
                  {
                    "name": "object",
                    "type": {
                      "annotated": {
                        "annotation": [
                          {
                            "@key": "description",
                            "@value": {"literal": {"string": "The object of the pattern"}}}],
                        "body": {"variable": "hydra.query.Node"}}}}]}}},
          "variables": []}}},
    {
      "type": {
        "name": "hydra.query.Variable",
        "type": {
          "constraints": null,
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {"literal": {"string": "A query variable"}}}],
              "body": {"wrap": {"literal": {"string": {}}}}}},
          "variables": []}}}],
  "description": ["A model for language-agnostic graph pattern queries"],
  "namespace": "hydra.query",
  "termDependencies": ["hydra.core"],
  "typeDependencies": ["hydra.core"]}

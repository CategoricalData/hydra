                              "annotated": {
                                "annotation": [
                                  {
                                    "@key": "description",
                                    "@value": {
                                      "literal": {
                                        "string": "A function which decodes target values as source values in a given context"}}}],
                                "body": {
                                  "function": {
                                    "codomain": {
                                      "function": {
                                        "codomain": {
                                          "either": {
                                            "left": {
                                              "application": {
                                                "argument": {"variable": "hydra.errors.Error"},
                                                "function": {"variable": "hydra.context.InContext"}}},
                                            "right": {"variable": "v1"}}},
                                        "domain": {"variable": "v2"}}},
                                    "domain": {"variable": "hydra.context.Context"}}}}}}]},
                      "parameter": "v2"}},
                  "parameter": "v1"}}}},
          "variables": []}}},

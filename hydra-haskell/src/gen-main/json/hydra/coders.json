{
  "definitions": [
    {
      "type": {
        "name": "hydra.coders.AdapterContext",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "An evaluation context together with a source language and a target language"}}}],
            "body": {
              "record": [
                {
                  "name": "graph",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {"string": "The underlying graph of elements and primitives"}}}],
                      "body": {"variable": "hydra.graph.Graph"}}}},
                {
                  "name": "language",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "The language being encoded or decoded"}}}],
                      "body": {"variable": "hydra.coders.Language"}}}},
                {
                  "name": "adapters",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {"string": "A map of type names to adapters for those types"}}}],
                      "body": {
                        "map": {
                          "keys": {"variable": "hydra.core.Name"},
                          "values": {
                            "application": {
                              "argument": {"variable": "hydra.core.Term"},
                              "function": {
                                "application": {
                                  "argument": {"variable": "hydra.core.Term"},
                                  "function": {
                                    "application": {
                                      "argument": {"variable": "hydra.core.Type"},
                                      "function": {
                                        "application": {
                                          "argument": {"variable": "hydra.core.Type"},
                                          "function": {"variable": "hydra.util.Adapter"}}}}}}}}}}}}}}]}}}}},
    {
      "type": {
        "name": "hydra.coders.CoderDirection",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "Indicates either the 'out' or the 'in' direction of a coder"}}}],
            "body": {
              "union": [
                {"name": "encode", "type": {"unit": {}}},
                {"name": "decode", "type": {"unit": {}}}]}}}}},
    {
      "type": {
        "name": "hydra.coders.Language",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A named language together with language-specific constraints"}}}],
            "body": {
              "record": [
                {
                  "name": "name",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "The unique name of the language"}}}],
                      "body": {"variable": "hydra.coders.LanguageName"}}}},
                {
                  "name": "constraints",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {"string": "The constraints which characterize the language"}}}],
                      "body": {"variable": "hydra.coders.LanguageConstraints"}}}}]}}}}},
    {
      "type": {
        "name": "hydra.coders.LanguageConstraints",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A set of constraints on valid type and term expressions, characterizing a language"}}}],
            "body": {
              "record": [
                {
                  "name": "eliminationVariants",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported elimination variants"}}}],
                      "body": {"set": {"variable": "hydra.variants.EliminationVariant"}}}}},
                {
                  "name": "literalVariants",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported literal variants"}}}],
                      "body": {"set": {"variable": "hydra.variants.LiteralVariant"}}}}},
                {
                  "name": "floatTypes",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported float types"}}}],
                      "body": {"set": {"variable": "hydra.core.FloatType"}}}}},
                {
                  "name": "functionVariants",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported function variants"}}}],
                      "body": {"set": {"variable": "hydra.variants.FunctionVariant"}}}}},
                {
                  "name": "integerTypes",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported integer types"}}}],
                      "body": {"set": {"variable": "hydra.core.IntegerType"}}}}},
                {
                  "name": "termVariants",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported term variants"}}}],
                      "body": {"set": {"variable": "hydra.variants.TermVariant"}}}}},
                {
                  "name": "typeVariants",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "All supported type variants"}}}],
                      "body": {"set": {"variable": "hydra.variants.TypeVariant"}}}}},
                {
                  "name": "types",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {
                            "literal": {
                              "string": "A logical set of types, as a predicate which tests a type for inclusion"}}}],
                      "body": {
                        "function": {
                          "codomain": {"literal": {"boolean": {}}},
                          "domain": {"variable": "hydra.core.Type"}}}}}}]}}}}},
    {
      "type": {
        "name": "hydra.coders.LanguageName",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {"literal": {"string": "The unique name of a language"}}}],
            "body": {"wrap": {"literal": {"string": {}}}}}}}},
    {
      "type": {
        "name": "hydra.coders.SymmetricAdapter",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A bidirectional encoder which maps between the same type and term languages on either side"}}}],
            "body": {
              "forall": {
                "body": {
                  "forall": {
                    "body": {
                      "application": {
                        "argument": {"variable": "v"},
                        "function": {
                          "application": {
                            "argument": {"variable": "v"},
                            "function": {
                              "application": {
                                "argument": {"variable": "t"},
                                "function": {
                                  "application": {
                                    "argument": {"variable": "t"},
                                    "function": {"variable": "hydra.util.Adapter"}}}}}}}}},
                    "parameter": "v"}},
                "parameter": "t"}}}}}},
    {
      "type": {
        "name": "hydra.coders.TraversalOrder",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {"string": "Specifies either a pre-order or post-order traversal"}}}],
            "body": {
              "union": [
                {
                  "name": "pre",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "Pre-order traversal"}}}],
                      "body": {"unit": {}}}}},
                {
                  "name": "post",
                  "type": {
                    "annotated": {
                      "annotation": [
                        {
                          "@key": "description",
                          "@value": {"literal": {"string": "Post-order traversal"}}}],
                      "body": {"unit": {}}}}}]}}}}},
    {
      "type": {
        "name": "hydra.coders.TypeAdapter",
        "type": {
          "annotated": {
            "annotation": [
              {
                "@key": "description",
                "@value": {
                  "literal": {
                    "string": "A function which maps a Hydra type to a symmetric adapter between types and terms"}}}],
            "body": {
              "function": {
                "codomain": {
                  "function": {
                    "codomain": {
                      "either": {
                        "left": {"literal": {"string": {}}},
                        "right": {
                          "application": {
                            "argument": {"variable": "hydra.core.Term"},
                            "function": {
                              "application": {
                                "argument": {"variable": "hydra.core.Type"},
                                "function": {"variable": "hydra.coders.SymmetricAdapter"}}}}}}},
                    "domain": {"variable": "hydra.core.Type"}}},
                "domain": {"variable": "hydra.coders.AdapterContext"}}}}}}}],
  "description": ["Abstractions for paired transformations between languages"],
  "namespace": "hydra.coders",
  "termDependencies": ["hydra.graph", "hydra.util", "hydra.variants"],
  "typeDependencies": ["hydra.core"]}

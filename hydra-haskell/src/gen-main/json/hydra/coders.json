    {
      "type": {
        "name": "hydra.coders.Coder",
        "type": {
          "type": {
            "annotated": {
              "annotation": [
                {
                  "@key": "description",
                  "@value": {
                    "literal": {
                      "string": "An encoder and decoder; a bidirectional transformation between two types"}}}],
              "body": {
                "forall": {
                  "body": {
                    "forall": {
                      "body": {
                        "record": [
                          {
